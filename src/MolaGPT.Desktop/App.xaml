<Application x:Class="MolaGPT.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MolaGPT.Desktop.Views"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Tokens.Light.xaml" />
                <ResourceDictionary Source="Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- App-level converter singletons referenced by XAML via {StaticResource}. -->
            <views:EnumEqualityConverter x:Key="EnumEq" />
            <BooleanToVisibilityConverter x:Key="BoolVis" />
            <views:NullToVisibilityConverter x:Key="NullVis" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
