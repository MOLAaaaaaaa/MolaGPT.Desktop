<Window x:Class="MolaGPT.Desktop.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MolaGPT.Desktop.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="发现新版本"
        Icon="/Assets/app-logo.png"
        Width="460" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="{DynamicResource Font.UI}"
        FontSize="{DynamicResource Font.Size.Body}"
        mc:Ignorable="d">

    <Grid Margin="24">
        <Border Style="{StaticResource ModalWindowGlow}" />
        <Border Style="{StaticResource ModalWindowSurface}"
                Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <StackPanel Style="{StaticResource InlineIconTextPanel}">
                        <TextBlock Text="&#xE777;"
                                   Style="{StaticResource InlineIconTextBlock}"
                                   FontSize="18"
                                   LineHeight="20"
                                   Margin="0,0,10,0"
                                   Foreground="{DynamicResource Brush.Primary}" />
                        <TextBlock x:Name="TitleText"
                                   Text="发现新版本"
                                   Style="{StaticResource InlineTextBlock}"
                                   FontSize="{DynamicResource Font.Size.Heading}"
                                   LineHeight="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource HeaderIconButton}"
                            Click="LaterClick"
                            ToolTip="稍后">
                        <TextBlock Text="&#xE711;" FontFamily="{DynamicResource Font.Icon}" FontSize="14" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock x:Name="VersionText"
                               FontSize="{DynamicResource Font.Size.Body}"
                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                </StackPanel>

                <Border Grid.Row="2"
                        Background="{DynamicResource Brush.Bg.Tertiary}"
                        CornerRadius="{DynamicResource Radius.Sm}"
                        Padding="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="14,12">
                        <controls:MarkdownPresenter x:Name="NotesMarkdown"
                                                    ThrottleMs="0"
                                                    CodeBlockMaxHeight="220" />
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource OutlineButton}"
                            Height="42"
                            Click="LaterClick"
                            Content="稍后再说" />
                    <Button Grid.Column="2"
                            x:Name="DownloadButton"
                            Style="{StaticResource PillPrimaryButton}"
                            Height="42"
                            Click="DownloadClick"
                            Content="立即下载" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
