<Window x:Class="MolaGPT.Desktop.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 MolaGPT Desktop"
        Icon="/Assets/app-logo.png"
        Width="620" Height="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="{DynamicResource Font.Cjk}"
        FontSize="{DynamicResource Font.Size.Body}"
        Foreground="{DynamicResource Brush.Text.Primary}">

    <Grid Margin="28">
        <Border Style="{StaticResource ModalWindowGlow}" />
        <Border Style="{StaticResource ModalWindowSurface}"
                Padding="0">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        Padding="24,18"
                        BorderBrush="{DynamicResource Brush.Divider}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="HeaderMouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="关于"
                                   FontSize="{DynamicResource Font.Size.Title}"
                                   FontWeight="Bold" />
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource HeaderIconButton}"
                                Click="CloseClick"
                                ToolTip="关闭">
                            <TextBlock Text="&#xE711;" FontFamily="{DynamicResource Font.Icon}" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="34,28,34,32">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="88"
                                    Height="88"
                                    CornerRadius="20"
                                    ClipToBounds="True"
                                    HorizontalAlignment="Center">
                                <Image Source="/Assets/app-logo.png"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <TextBlock Text="MolaGPT Desktop"
                                       HorizontalAlignment="Center"
                                       Margin="0,18,0,4"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                            <TextBox x:Name="VersionText"
                                     Style="{StaticResource SelectableBlockTextBox}"
                                     HorizontalAlignment="Center"
                                     FontSize="{DynamicResource Font.Size.Small}"
                                     Foreground="{DynamicResource Brush.Text.Muted}" />
                            <TextBlock Text="自由、开放的 MolaGPT 及其他 LLM API 的 Windows 实现"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="430"
                                       Margin="0,16,0,0"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,26,0,6">
                            <Button x:Name="CheckUpdateButton"
                                    Style="{StaticResource PillPrimaryButton}"
                                    Padding="18,9"
                                    Margin="0,0,12,0"
                                    Click="CheckUpdateClick">
                                <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                    <TextBlock Text="&#xE895;"
                                               Style="{StaticResource InlineIconTextBlock}"
                                               Margin="0,0,8,0" />
                                    <TextBlock x:Name="CheckUpdateText"
                                               Text="检查更新"
                                               Style="{StaticResource InlineTextBlock}" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource OutlineButton}"
                                    Padding="18,9"
                                    Click="OpenGitHubClick">
                                <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                    <TextBlock Text="&#xE774;"
                                               Style="{StaticResource InlineIconTextBlock}"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="GitHub 主页"
                                               Style="{StaticResource InlineTextBlock}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="开源项目"
                                   Margin="0,34,0,6"
                                   FontSize="{DynamicResource Font.Size.XSmall}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Muted}" />
                        <TextBlock Text="MolaGPT Desktop 构建于以下优秀的开源项目之上，在此致谢。"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   FontSize="{DynamicResource Font.Size.Small}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" />

                        <Border Background="{DynamicResource Brush.Bg.Primary}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Lg}">
                            <ItemsControl x:Name="DependencyList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource Brush.Divider}"
                                                BorderThickness="0,0,0,1"
                                                Padding="16,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Margin="0,2,0,0"
                                                               FontSize="{DynamicResource Font.Size.Small}"
                                                               Foreground="{DynamicResource Brush.Text.Muted}" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource Brush.Bg.Tertiary}"
                                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="9,4"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding License}"
                                                               FontSize="{DynamicResource Font.Size.XSmall}"
                                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <TextBlock TextWrapping="Wrap"
                                   Margin="0,14,0,0"
                                   FontSize="{DynamicResource Font.Size.Small}"
                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                   Text="「远程 Agent 控制」的桥接 / 中继架构与 CLI 控制协议设计参考了开源项目 Remodex（Apache-2.0，github.com/Emanuele-web04/remodex），本实现为独立编写，未直接复制其源码，在此一并致谢。" />

                        <TextBlock Text="开放源代码协议"
                                   Margin="0,32,0,12"
                                   FontSize="{DynamicResource Font.Size.XSmall}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Muted}" />
                        <Expander>
                            <Expander.Header>
                                <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                    <TextBlock Text="&#xE8A5;"
                                               Style="{StaticResource InlineIconTextBlock}"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="查看完整开源许可证"
                                               Style="{StaticResource InlineTextBlock}" />
                                </StackPanel>
                            </Expander.Header>
                            <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource Radius.Md}"
                                    Padding="16"
                                    Margin="0,12,0,0"
                                    MaxHeight="330">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox x:Name="LicenseText"
                                             Style="{StaticResource SelectableBlockTextBox}"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Foreground="{DynamicResource Brush.Text.Secondary}"
                                             VerticalScrollBarVisibility="Disabled" />
                                </ScrollViewer>
                            </Border>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
