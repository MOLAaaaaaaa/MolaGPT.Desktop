<UserControl x:Class="MolaGPT.Desktop.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MolaGPT.ViewModels;assembly=MolaGPT.ViewModels"
             xmlns:views="clr-namespace:MolaGPT.Desktop.Views"
             d:DataContext="{d:DesignInstance vm:ChatViewModel}"
             mc:Ignorable="d"
             Background="Transparent"
             Focusable="False">
    <!-- Centered welcome header with logo, greeting, and prompt suggestions. -->
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
        <StackPanel HorizontalAlignment="Center" MaxWidth="720">

            <!-- Inline brand row: logo + greeting on one line. -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10">
                <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0" ClipToBounds="True">
                    <Image Source="/Assets/app-logo.png"
                           Stretch="UniformToFill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
                <TextBlock Text="时刻准备着。"
                           FontSize="20"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.Text.Primary}" />
            </StackPanel>

            <TextBlock Text="问点什么，或者从下方挑一个开始。"
                       FontSize="{DynamicResource Font.Size.Body}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"
                       Opacity="0.75"
                       Foreground="{DynamicResource Brush.Text.Secondary}" />

            <ItemsControl ItemsSource="{Binding HintChips}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource HintChip}"
                                Content="{Binding}"
                                Click="HintChip_Click" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Persona quick-pick row — BYOK mode only.
                 Visible whenever a BYOK provider is active (or no provider is
                 registered yet). Hidden in MolaGPT-account mode because the
                 server owns its own system prompts. -->
            <StackPanel HorizontalAlignment="Center"
                        Margin="0,28,0,0"
                        Visibility="{Binding IsBYOKActive, Converter={x:Static views:BoolToVisibility.Instance}}">
                <TextBlock Text="或者从一个角色开始"
                           FontSize="{DynamicResource Font.Size.Small}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"
                           Foreground="{DynamicResource Brush.Text.Muted}" />
                <ItemsControl ItemsSource="{Binding Personas.Personas}"
                              HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="PersonaCard_Click"
                                    Tag="{Binding Id}"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="6">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="card"
                                                Background="{DynamicResource Brush.Bg.Elevated}"
                                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                BorderThickness="1"
                                                CornerRadius="{DynamicResource Radius.Md}"
                                                Padding="14,12"
                                                MinWidth="140"
                                                MaxWidth="180">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayAvatar}"
                                                           FontFamily="{DynamicResource Font.Icon}"
                                                           FontSize="22"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource Brush.Primary}" />
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,6,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="card" Property="BorderBrush"
                                                        Value="{DynamicResource Brush.Primary.Border}" />
                                                <Setter TargetName="card" Property="Background"
                                                        Value="{DynamicResource Brush.Primary.Soft}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

