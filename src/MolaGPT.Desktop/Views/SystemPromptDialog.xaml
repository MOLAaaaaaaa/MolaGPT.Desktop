<Window x:Class="MolaGPT.Desktop.Views.SystemPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="会话提示词"
        Icon="/Assets/app-logo.png"
        Width="660" Height="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="{DynamicResource Font.UI}"
        FontSize="{DynamicResource Font.Size.Body}"
        KeyDown="Window_KeyDown">

    <Grid Margin="24">
        <Border Style="{StaticResource ModalWindowGlow}" />
        <Border Style="{StaticResource ModalWindowSurface}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="{DynamicResource Brush.Bg.Tertiary}"
                        CornerRadius="20,20,0,0"
                        BorderBrush="{DynamicResource Brush.Divider}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid Margin="20,0">
                        <StackPanel Style="{StaticResource InlineIconTextPanel}">
                            <TextBlock Text="&#xE8A5;"
                                       Style="{StaticResource InlineIconTextBlock}"
                                       FontSize="14"
                                       Margin="0,0,8,0"
                                       Foreground="{DynamicResource Brush.Primary}" />
                            <TextBlock Text="会话提示词" Style="{StaticResource InlineTextBlock}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                            <TextBlock Text="为当前对话临时改写系统提示词"
                                       Style="{StaticResource InlineTextBlock.Small}"
                                       Margin="10,0,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource Brush.Text.Muted}" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Style="{StaticResource HeaderIconButton}"
                                Click="CloseClick">
                            <TextBlock Text="&#xE711;" FontFamily="{DynamicResource Font.Icon}" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="22,18,22,16">

                        <!-- Active persona panel -->
                        <Border x:Name="PersonaPanel"
                                Background="{DynamicResource Brush.Primary.Soft}"
                                BorderBrush="{DynamicResource Brush.Primary.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Md}"
                                Padding="14,10"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PersonaAvatar"
                                           Text="&#xE99A;"
                                           FontFamily="{DynamicResource Font.Icon}"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="当前角色 · "
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock x:Name="PersonaName"
                                                   Text="未选择"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="PersonaHint"
                                               FontSize="11"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Mode selector — only meaningful when a persona is bound. -->
                        <StackPanel x:Name="ModePanel" Margin="0,0,0,12">
                            <TextBlock Text="提示词来源"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       Margin="0,0,0,6" />
                            <StackPanel>
                                <RadioButton x:Name="ModeInheritRadio"
                                             GroupName="PromptMode"
                                             Content="使用角色默认提示词（推荐）"
                                             IsChecked="True"
                                             Checked="ModeChanged"
                                             Margin="0,0,0,4" />
                                <RadioButton x:Name="ModeAppendRadio"
                                             GroupName="PromptMode"
                                             Content="在角色提示词之后追加"
                                             Checked="ModeChanged"
                                             Margin="0,0,0,4" />
                                <RadioButton x:Name="ModeOverrideRadio"
                                             GroupName="PromptMode"
                                             Content="完全替换为下方文本"
                                             Checked="ModeChanged" />
                            </StackPanel>
                            <TextBlock x:Name="ModeHint"
                                       FontSize="11"
                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- No-persona mode: simpler choice between empty and explicit. -->
                        <StackPanel x:Name="NoPersonaModePanel" Margin="0,0,0,12" Visibility="Collapsed">
                            <TextBlock Text="提示词"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       Margin="0,0,0,6" />
                            <StackPanel>
                                <RadioButton x:Name="NoPersonaEmptyRadio"
                                             GroupName="NoPersonaMode"
                                             Content="不发送 system 消息（默认）"
                                             IsChecked="True"
                                             Checked="NoPersonaModeChanged"
                                             Margin="0,0,0,4" />
                                <RadioButton x:Name="NoPersonaCustomRadio"
                                             GroupName="NoPersonaMode"
                                             Content="使用下方文本作为 system 消息"
                                             Checked="NoPersonaModeChanged" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Editor -->
                        <TextBlock x:Name="EditorLabel"
                                   Text="本次对话的提示词"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   Margin="0,0,0,6" />

                        <Border x:Name="EditorBorder"
                                Background="{DynamicResource Brush.Bg.Primary}"
                                CornerRadius="{DynamicResource Radius.Sm}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                Padding="12,10"
                                Height="200">
                            <TextBox x:Name="PromptTextBox"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource Brush.Text.Primary}"
                                     FontSize="13"
                                     TextChanged="PromptTextChanged" />
                        </Border>

                        <!-- Variable chips — clicking inserts the token into the editor. -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="可用变量："
                                       FontSize="11"
                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <ItemsControl>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <Button Tag="{}{{date}}" Click="InsertVariableClick"
                                        Content="{}{{date}}" ToolTip="今日日期，例如 2026-05-27"
                                        Style="{StaticResource HintChip}"
                                        Padding="10,3" Margin="0,0,6,4" />
                                <Button Tag="{}{{time}}" Click="InsertVariableClick"
                                        Content="{}{{time}}" ToolTip="当前时间，例如 14:30"
                                        Style="{StaticResource HintChip}"
                                        Padding="10,3" Margin="0,0,6,4" />
                                <Button Tag="{}{{datetime}}" Click="InsertVariableClick"
                                        Content="{}{{datetime}}" ToolTip="完整日期与时间"
                                        Style="{StaticResource HintChip}"
                                        Padding="10,3" Margin="0,0,6,4" />
                                <Button Tag="{}{{model}}" Click="InsertVariableClick"
                                        Content="{}{{model}}" ToolTip="当前模型名称"
                                        Style="{StaticResource HintChip}"
                                        Padding="10,3" Margin="0,0,6,4" />
                                <Button Tag="{}{{provider}}" Click="InsertVariableClick"
                                        Content="{}{{provider}}" ToolTip="当前服务提供商"
                                        Style="{StaticResource HintChip}"
                                        Padding="10,3" Margin="0,0,6,4" />
                                <Button Tag="{}{{username}}" Click="InsertVariableClick"
                                        Content="{}{{username}}" ToolTip="MolaGPT 账号用户名（未登录时为“用户”）"
                                        Style="{StaticResource HintChip}"
                                        Padding="10,3" Margin="0,0,6,4" />
                            </ItemsControl>
                        </StackPanel>

                        <!-- Persona prompt full reference (collapsible) -->
                        <Expander x:Name="PersonaPromptExpander"
                                  Header="查看角色默认提示词"
                                  Margin="0,12,0,0"
                                  Foreground="{DynamicResource Brush.Text.Secondary}">
                            <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                    CornerRadius="{DynamicResource Radius.Sm}"
                                    Padding="12,10"
                                    Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBox x:Name="PersonaPromptBox"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MaxHeight="180"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource Brush.Text.Primary}"
                                             FontSize="12" />
                                    <Button Content="复制到编辑框作为起点"
                                            Click="CopyPersonaToEditorClick"
                                            Style="{StaticResource OutlineButton}"
                                            Padding="12,4"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource Brush.Divider}"
                        BorderThickness="0,1,0,0"
                        Padding="22,12,22,16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="ResetButton"
                                Content="恢复默认" Style="{StaticResource OutlineButton}"
                                Padding="16,8" Margin="0,0,8,0"
                                ToolTip="切回'使用角色默认提示词'并清空下方文本"
                                Click="ResetClick" />
                        <Button Content="取消" Style="{StaticResource OutlineButton}"
                                Padding="16,8" Margin="0,0,8,0"
                                Click="CloseClick" />
                        <Button Content="保存" Style="{StaticResource PillPrimaryButton}"
                                Padding="16,8"
                                Click="SaveClick" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
