<UserControl x:Class="MolaGPT.Desktop.Views.ComposerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MolaGPT.ViewModels;assembly=MolaGPT.ViewModels"
             xmlns:views="clr-namespace:MolaGPT.Desktop.Views"
             d:DataContext="{d:DesignInstance vm:ComposerViewModel}"
             mc:Ignorable="d"
             Background="Transparent">

    <!-- Floating composer card. The layout uses a compact four-row grid:
         row 0 = attachment chips +
         optional file count / row 1 = action toolbar (附件/推理/推理强度/网络) /
         row 2 = textarea / row 3 = action bar (hint, send/stop). -->
    <Border Background="{DynamicResource Brush.Bg.Elevated}"
            BorderBrush="{DynamicResource Brush.Border.Strong}"
            BorderThickness="1.5"
            CornerRadius="{DynamicResource Radius.Xl}"
            Padding="14,10"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: attachment cards. Header row shows count + clear-all;
                 below it is a horizontal wrap of cards. Image cards expose a 32×32 thumbnail
                 and open ImagePreviewWindow on click; non-image cards show a
                 typed icon. The whole strip collapses when Attachments is empty. -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.Bg.Tertiary}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.Sm}"
                    Padding="8,5"
                    Margin="0,0,0,6"
                    Visibility="{Binding HasAttachments, Converter={x:Static views:BoolToVisibility.Instance}}">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE723;"
                                       FontFamily="{DynamicResource Font.Icon}"
                                       FontSize="11"
                                       Margin="0,0,4,0"
                                       Foreground="{DynamicResource Brush.Primary}"
                                       VerticalAlignment="Center" />
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       VerticalAlignment="Center">
                                <Run Text="已上传 " />
                                <Run Text="{Binding Attachments.Count, Mode=OneWay}"
                                     Foreground="{DynamicResource Brush.Primary}"
                                     FontWeight="SemiBold" />
                                <Run Text=" 个文件" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="6,2"
                                Cursor="Hand"
                                FontSize="11"
                                Foreground="{DynamicResource Brush.Text.Secondary}"
                                Command="{Binding ClearAttachmentsCommand}"
                                ToolTip="清空所有文件">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;"
                                           FontFamily="{DynamicResource Font.Icon}"
                                           FontSize="10"
                                           Margin="0,0,3,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="清空" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Attachments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Padding="6,4"
                                        Margin="0,0,6,4"
                                        MaxWidth="180"
                                        MinWidth="96"
                                        MouseLeftButtonUp="OnAttachmentCardClick"
                                        ToolTip="{Binding FileName}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                    <Setter Property="Cursor" Value="Hand" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 32×32 thumbnail: image preview or file glyph -->
                                        <Border Width="32" Height="32"
                                                CornerRadius="3"
                                                Background="{DynamicResource Brush.Bg.Tertiary}"
                                                Margin="0,0,6,0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image Source="{Binding Bytes, Converter={x:Static views:BytesToImageConverter.Instance}}"
                                                       Stretch="UniformToFill"
                                                       Visibility="{Binding IsImage, Converter={x:Static views:BoolToVisibility.Instance}}" />
                                                <TextBlock Text="&#xE7C3;"
                                                           FontFamily="{DynamicResource Font.Icon}"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding IsImage, Converter={x:Static views:BoolToVisibilityInverse.Instance}}" />
                                            </Grid>
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileName, FallbackValue=附件}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />

                                        <Button Grid.Column="2"
                                                Margin="4,0,0,0"
                                                Width="18" Height="18"
                                                Padding="0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Opacity="0.55"
                                                ToolTip="移除"
                                                Click="OnRemoveAttachmentClick">
                                            <TextBlock Text="&#xE711;"
                                                       FontFamily="{DynamicResource Font.Icon}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Brush.Text.Muted}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Row 1: toolbar buttons. Attachment is always visible; thinking
                 and reasoning-effort controls depend on the active model; network
                 and webpage reading are exposed as separate toggles. -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                <!-- 角色 / Persona picker — BYOK mode only. Shows current persona's
                     avatar + name, click to open a popup with the full registry. -->
                <ToggleButton x:Name="PersonaToggle"
                              Style="{StaticResource ToolToggleButton}"
                              Visibility="{Binding IsPersonaPickerVisible, Converter={x:Static views:BoolToVisibility.Instance}}"
                              ToolTip="选择对话角色 / 系统提示词">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Chat.ActivePersonaAvatar}"
                                   FontFamily="{DynamicResource Font.Icon}"
                                   FontSize="13"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Chat.ActivePersonaName}" />
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="PersonaPopup"
                       IsOpen="{Binding IsChecked, ElementName=PersonaToggle}"
                       PlacementTarget="{Binding ElementName=PersonaToggle}"
                       Placement="Top"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="{DynamicResource Brush.Bg.Elevated}"
                            BorderBrush="{DynamicResource Brush.Border.Strong}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Radius.Md}"
                            Padding="0"
                            MinWidth="320"
                            MaxWidth="420"
                            Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect Color="#33000000" BlurRadius="14" ShadowDepth="4" Opacity="0.35" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Grid Grid.Row="0" Margin="14,12,14,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="选择角色"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Click="OnClearPersonaClick"
                                        Style="{StaticResource ToolPlainButton}"
                                        Padding="8,2"
                                        ToolTip="清除当前对话的角色绑定，恢复默认助手"
                                        Visibility="{Binding Chat.ActivePersonaId, Converter={x:Static views:NullToInverseVisibility.Instance}}">
                                    <TextBlock Text="清除角色" FontSize="11" />
                                </Button>
                            </Grid>

                            <!-- Persona list -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="360"
                                          Padding="8,0,8,0">
                                <ItemsControl ItemsSource="{Binding Personas.Personas}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="OnPickPersonaClick"
                                                    Tag="{Binding Id}"
                                                    Cursor="Hand"
                                                    HorizontalContentAlignment="Stretch"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FocusVisualStyle="{x:Null}"
                                                    Padding="0"
                                                    Margin="0,1">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="row"
                                                                Background="Transparent"
                                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                                Padding="10,8">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="row" Property="Background"
                                                                        Value="{DynamicResource Brush.Bg.HoverOverlay}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding DisplayAvatar}"
                                                               FontFamily="{DynamicResource Font.Icon}"
                                                               FontSize="16"
                                                               Width="28"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Preview}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <!-- Active checkmark -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="&#xE73E;"
                                                               FontFamily="{DynamicResource Font.Icon}"
                                                               FontSize="14"
                                                               Foreground="{DynamicResource Brush.Primary}"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0">
                                                        <TextBlock.Visibility>
                                                            <MultiBinding Converter="{x:Static views:EqualityToVisibility.Instance}">
                                                                <Binding Path="Id" />
                                                                <Binding Path="DataContext.Chat.ActivePersonaId"
                                                                         RelativeSource="{RelativeSource AncestorType=Popup}" />
                                                            </MultiBinding>
                                                        </TextBlock.Visibility>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Footer: new + manage -->
                            <Border Grid.Row="2"
                                    BorderBrush="{DynamicResource Brush.Divider}"
                                    BorderThickness="0,1,0,0"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Click="OnNewPersonaClick"
                                            Style="{StaticResource ToolPlainButton}"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE710;"
                                                       FontFamily="{DynamicResource Font.Icon}"
                                                       FontSize="12"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="新建角色" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Click="OnManagePersonasClick"
                                            Style="{StaticResource ToolPlainButton}"
                                            HorizontalAlignment="Right">
                                        <TextBlock Text="管理…" />
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Popup>

                <!-- 附件 -->
                <Button Style="{StaticResource ToolPlainButton}"
                        Click="OnAttachClick"
                        ToolTip="上传文件 / 图片"
                        Visibility="{Binding IsAttachVisible, Converter={x:Static views:BoolToVisibility.Instance}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE723;" FontFamily="{DynamicResource Font.Icon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="附件" />
                    </StackPanel>
                </Button>

                <!-- 推理 (thinking toggle) — auto-hides on non-reasoning models -->
                <ToggleButton Style="{StaticResource ToolToggleButton}"
                              IsChecked="{Binding EnableThinking}"
                              ToolTip="开启推理：复杂问题先推理后回答"
                              Visibility="{Binding IsThinkingVisible, Converter={x:Static views:BoolToVisibility.Instance}}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Lightbulb icon -->
                        <TextBlock Text="&#xE82F;" FontFamily="{DynamicResource Font.Icon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="推理" />
                    </StackPanel>
                </ToggleButton>

                <!-- 推理强度 — popup adapts to ActiveThinkingKind -->
                <ToggleButton x:Name="EffortToggle"
                              Style="{StaticResource ToolToggleButton}"
                              ToolTip="调整推理强度"
                              Visibility="{Binding IsReasoningEffortVisible, Converter={x:Static views:BoolToVisibility.Instance}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF8B0;" FontFamily="{DynamicResource Font.Icon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock>
                            <Run Text="强度: " />
                            <Run Text="{Binding ReasoningEffortLabel, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </ToggleButton>
                <Popup IsOpen="{Binding IsChecked, ElementName=EffortToggle}"
                       PlacementTarget="{Binding ElementName=EffortToggle}"
                       Placement="Top"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="{DynamicResource Brush.Bg.Elevated}"
                            BorderBrush="{DynamicResource Brush.Border.Strong}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Radius.Md}"
                            Padding="12,10"
                            Margin="0,0,0,6">
                        <Border.Effect>
                            <DropShadowEffect Color="#33000000" BlurRadius="12" ShadowDepth="4" Opacity="0.3" />
                        </Border.Effect>
                        <StackPanel MinWidth="220">
                            <TextBlock Text="推理强度"
                                       FontWeight="SemiBold"
                                       FontSize="{DynamicResource Font.Size.Small}"
                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                       Margin="0,0,0,8" />
                            <!-- Chip-style picker for reasoning effort:
                                 WrapPanel of selectable pills, each one
                                 maps a single value (low/medium/high/...). ListBox carries
                                 the SelectedItem ↔ ReasoningEffort binding; the
                                 ComposerViewModel normalizes the value when the model
                                 changes so the ListBox never silently writes null. -->
                            <ListBox x:Name="EffortChips"
                                     ItemsSource="{Binding AvailableEffortLevels}"
                                     SelectedItem="{Binding ReasoningEffort, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     Margin="0,0,0,4"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     Visibility="{Binding IsEffortComboVisible, Converter={x:Static views:BoolToVisibility.Instance}}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Margin" Value="0,0,6,6" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="chipBorder"
                                                            Background="{DynamicResource Brush.Bg.Tertiary}"
                                                            BorderBrush="{DynamicResource Brush.Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="{DynamicResource Radius.Sm}"
                                                            Padding="12,5">
                                                        <TextBlock x:Name="chipText"
                                                                   Text="{Binding Converter={x:Static views:EffortLabelConverter.Instance}}"
                                                                   FontSize="{DynamicResource Font.Size.Small}"
                                                                   Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="chipBorder" Property="BorderBrush" Value="{DynamicResource Brush.Primary.Border}" />
                                                            <Setter TargetName="chipText" Property="Foreground" Value="{DynamicResource Brush.Primary.Hover}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="chipBorder" Property="Background" Value="{DynamicResource Brush.Primary.Soft}" />
                                                            <Setter TargetName="chipBorder" Property="BorderBrush" Value="{DynamicResource Brush.Primary}" />
                                                            <Setter TargetName="chipText" Property="Foreground" Value="{DynamicResource Brush.Primary}" />
                                                            <Setter TargetName="chipText" Property="FontWeight" Value="SemiBold" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            <StackPanel Visibility="{Binding IsBudgetSliderVisible, Converter={x:Static views:BoolToVisibility.Instance}}">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Token Budget"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ThinkingBudgetTokens}"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Primary}" />
                                </Grid>
                                <Slider Minimum="{Binding BudgetMin}"
                                        Maximum="{Binding BudgetMax}"
                                        Value="{Binding ThinkingBudgetTokens, Mode=TwoWay}"
                                        TickFrequency="1024"
                                        IsSnapToTickEnabled="False"
                                        SmallChange="512"
                                        LargeChange="4096" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- 联网搜索 -->
                <ToggleButton Style="{StaticResource ToolToggleButton}"
                              IsChecked="{Binding EnableNetwork}"
                              IsEnabled="{Binding AreNetworkToolsEnabled}"
                              ToolTip="联网搜索">
                    <StackPanel Orientation="Horizontal">
                        <!-- Search glyph -->
                        <TextBlock Text="&#xE721;" FontFamily="{DynamicResource Font.Icon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="联网搜索" />
                    </StackPanel>
                </ToggleButton>

                <!-- 网页阅读 / web_fetch -->
                <ToggleButton Style="{StaticResource ToolToggleButton}"
                              IsChecked="{Binding EnableWebFetch}"
                              IsEnabled="{Binding AreNetworkToolsEnabled}"
                              ToolTip="网页阅读">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE774;" FontFamily="{DynamicResource Font.Icon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="网页阅读" />
                    </StackPanel>
                </ToggleButton>
            </StackPanel>

            <!-- Row 2: textarea -->
            <TextBox x:Name="InputBox"
                     Grid.Row="2"
                     Style="{StaticResource ComposerTextBox}"
                     Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                     PreviewKeyDown="InputBox_PreviewKeyDown" />

            <!-- Row 3: action bar (left hint, right send/stop) -->
            <Grid Grid.Row="3" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.Text.Muted}"
                           FontSize="{DynamicResource Font.Size.XSmall}"
                           Text="Enter 发送 · Shift+Enter 换行" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SendButton"
                            Style="{StaticResource SendButton}"
                            Command="{Binding SendCommand}"
                            ToolTip="发送 (Ctrl+Enter)"
                            Visibility="{Binding IsSending,
                                                  Converter={x:Static views:BoolToVisibilityInverse.Instance}}">
                        <TextBlock Text="&#xE724;" FontFamily="{DynamicResource Font.Icon}" />
                    </Button>
                    <Button Style="{StaticResource StopButton}"
                            Command="{Binding StopCommand}"
                            ToolTip="停止"
                            Visibility="{Binding IsSending,
                                                  Converter={x:Static views:BoolToVisibility.Instance}}">
                        <TextBlock Text="&#xE71A;" FontFamily="{DynamicResource Font.Icon}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
