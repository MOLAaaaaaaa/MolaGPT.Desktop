                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="12,8">
                                                    <TextBox x:Name="WebSearchBaseUrlBox"
                                                             Style="{StaticResource InlineTextBox}"
                                                             Text="{Binding WebSearchBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="API Key" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="12,8">
                                                    <ctl:RevealableSecretBox x:Name="WebSearchApiKeyBox"
                                                                             PasswordChanged="WebSearchApiKeyBox_PasswordChanged" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="每次返回结果数" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             Text="{Binding WebSearchMaxResults, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="网页正文截取上限（字符）" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             Text="{Binding WebPageMaxCharacters, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="WebSearchStatusText"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,16,0"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SettingsRowHint}" />
                                            <Button x:Name="CheckWebSearchButton"
                                                    Grid.Column="1"
                                                    Style="{StaticResource OutlineButton}"
                                                    Content="测试连接"
                                                    Width="110"
                                                    Click="CheckWebSearchClick" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="图像生成">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,26" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="图像生成" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}"
                                           Text="为 BYOK 文本对话配置可调用的图像生成服务。" />

                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingsRowTitle}" Text="在对话中启用图像生成" />
                                            <TextBlock Style="{StaticResource SettingsRowHint}"
                                                       Text="开启后，支持工具调用的 BYOK 模型可调用此图像服务。" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      x:Name="ImageGenerationEnabledToggle"
                                                      Style="{StaticResource SettingsToggle}"
                                                      IsChecked="{Binding ImageGenerationEnabled, Mode=TwoWay}" />
                                    </Grid>
                                </Border>

                                <StackPanel IsEnabled="{Binding IsChecked, ElementName=ImageGenerationEnabledToggle}">
                                    <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="生成参数" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel Margin="16,14">
                                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="图像服务 / 模型" />
                                            <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="12,2"
                                                    Margin="0,0,0,14">
                                                <ComboBox x:Name="ImageGenerationModelCombo"
                                                          Style="{StaticResource SettingsComboBox}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0,6"
                                                          DisplayMemberPath="Label"
                                                          SelectionChanged="ImageGenerationModelCombo_SelectionChanged" />
                                            </Border>

                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="尺寸" />
                                                    <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                            BorderBrush="{DynamicResource Brush.Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="{DynamicResource Radius.Sm}"
                                                            Padding="12,8">
                                                        <TextBox Style="{StaticResource InlineTextBox}"
                                                                 Text="{Binding ImageGenerationSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="风格（可选）" />
                                                    <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                            BorderBrush="{DynamicResource Brush.Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="{DynamicResource Radius.Sm}"
                                                            Padding="12,8">
                                                        <TextBox Style="{StaticResource InlineTextBox}"
                                                                 Text="{Binding ImageGenerationStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="ImageGenerationStatusText"
                                                           Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,16,0"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource SettingsRowHint}" />
                                                <Button x:Name="CheckImageGenerationButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource OutlineButton}"
                                                        Content="测试连接"
                                                        Width="110"
                                                        Click="CheckImageGenerationClick" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="视觉理解">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,26" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="视觉理解" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}"
                                           Text="为不支持图片输入、但支持工具调用的模型，外挂一个视觉模型来识别图片。" />

                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingsRowTitle}" Text="启用外挂视觉" />
                                            <TextBlock Style="{StaticResource SettingsRowHint}"
                                                       Text="当前模型不支持视觉时，自动用下方视觉模型解析图片，再把描述回传给主模型。" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      x:Name="VisionEnabledToggle"
                                                      Style="{StaticResource SettingsToggle}"
                                                      IsChecked="{Binding VisionProxyEnabled, Mode=TwoWay}" />
                                    </Grid>
                                </Border>

                                <StackPanel x:Name="VisionConfigPanel"
                                            IsEnabled="{Binding IsChecked, ElementName=VisionEnabledToggle}">
                                    <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="视觉模型" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel Margin="16,14">
                                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="选择模型" />
                                            <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="12,2">
                                                <ComboBox x:Name="VisionExistingModelCombo"
                                                          Style="{StaticResource SettingsComboBox}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0,6"
                                                          DisplayMemberPath="Label"
                                                          SelectionChanged="VisionExistingModelCombo_SelectionChanged" />
                                            </Border>
                                            <TextBlock Style="{StaticResource SettingsRowHint}"
                                                       Text="仅列出已启用、且具备视觉能力的服务与模型。可在「模型服务」中为模型勾选视觉能力。" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="沙箱与文件">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,26" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="沙箱与文件" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}"
                                           Text="让 BYOK 模型在对话中按需运行 Python 代码、读取本地文件。" />

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Margin="2,4,2,8" Text="本地 Python 执行" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingsRowTitle}" Text="启用 Python 执行" />
                                            <TextBlock Style="{StaticResource SettingsRowHint}" Text="BYOK 对话中按需运行 Python 代码并返回结果。" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      x:Name="PythonToolEnabledToggle"
                                                      Style="{StaticResource SettingsToggle}"
                                                      IsChecked="{Binding PythonToolEnabled, Mode=TwoWay}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel Margin="16,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="PythonRuntimeStatusText"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource SettingsRowTitle}" />
                                                <TextBlock x:Name="PythonRuntimeDetailText"
                                                           TextWrapping="Wrap"
                                                           Margin="0,3,0,0"
                                                           Style="{StaticResource SettingsRowHint}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button x:Name="ConfigurePythonRuntimeButton"
                                                        Style="{StaticResource OutlineButton}"
                                                        Content="一键配置"
                                                        Height="32"
                                                        Padding="16,0"
                                                        Margin="0,0,6,0"
                                                        Click="ConfigurePythonRuntimeClick" />
                                                <Button x:Name="ClearPythonRuntimeButton"
                                                        Style="{StaticResource OutlineButton}"
                                                        Content="重置环境"
                                                        Height="32"
                                                        Padding="14,0"
                                                        Visibility="Collapsed"
                                                        ToolTip="删除专属运行时和会话依赖缓存，保留用户产物"
                                                        Click="ClearPythonRuntimeClick" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="解释器路径" />
                                        <DockPanel LastChildFill="True">
                                            <Button x:Name="OpenPythonRuntimeDirectoryButton"
                                                    DockPanel.Dock="Right"
                                                    Style="{StaticResource OutlineButton}"
                                                    Content="浏览…"
                                                    Height="36"
                                                    Padding="14,0"
                                                    Margin="8,0,0,0"
                                                    ToolTip="选择 python.exe 位置"
                                                    Click="OpenPythonRuntimeDirectoryClick" />
                                            <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="12,8"
                                                    VerticalAlignment="Center">
                                                <TextBox Style="{StaticResource InlineTextBox}"
                                                         Text="{Binding PythonToolExecutablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel Margin="16,14">
                                        <Grid Margin="0,0,0,16" IsEnabled="{Binding IsChecked, ElementName=PythonToolEnabledToggle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="超时（秒）" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             Text="{Binding PythonToolTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="输出上限（字符）" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             Text="{Binding PythonToolMaxOutputCharacters, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <Grid IsEnabled="{Binding IsChecked, ElementName=PythonToolEnabledToggle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="联网访问" />
                                                <TextBlock Style="{StaticResource SettingsRowHint}" Text="允许代码发起网络请求和安装第三方包" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource SettingsToggle}"
                                                          IsChecked="{Binding PythonToolAllowNetwork, Mode=TwoWay}" />
                                        </Grid>

                                    </StackPanel>
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="文件工具（只读）" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingsRowTitle}" Text="启用只读文件工具" />
                                            <TextBlock Style="{StaticResource SettingsRowHint}"
                                                       Text="允许模型用 Read / Glob / Grep 读取、查找、搜索本地文件（只读，受 Python 的拒绝路径限制）。" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource SettingsToggle}"
                                                      IsChecked="{Binding FileToolsEnabled, Mode=TwoWay}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="审批与安全">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,26" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="审批与安全" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}"
                                           Text="控制工具调用的审批策略，以及 Python 执行的自动放行与拦截规则。" />

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="所有本地工具" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel Margin="16,14">
                                        <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="统一权限模式" />
                                        <Border Style="{StaticResource SettingsSegmentTrack}" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton Content="审批权限（默认）"
                                                             GroupName="ToolPermissionMode"
                                                             Style="{StaticResource SettingsSegment}"
                                                             IsChecked="{Binding LocalToolPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=Approval}" />
                                                <RadioButton Content="完全权限"
                                                             GroupName="ToolPermissionMode"
                                                             Style="{StaticResource SettingsSegment}"
                                                             IsChecked="{Binding LocalToolPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=FullAccess}" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Style="{StaticResource SettingsRowHint}"
                                                   Text="读取工具自动放行；写入、外部副作用和破坏性操作进入统一审批。完全权限可跳过普通写入审批，但破坏性操作和 Python 包安装仍需确认。" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="按工具类型" />
                                <Border Style="{StaticResource SettingsCard}"
                                        IsEnabled="{Binding LocalToolPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=Approval}">
                                    <StackPanel Margin="16,12">
                                        <!-- Image generation -->
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="图像生成" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Style="{StaticResource SettingsSegmentTrack}">
                                                <StackPanel Orientation="Horizontal">
                                                    <RadioButton Content="审批"
                                                                 GroupName="ImageGenPermMode"
                                                                 Style="{StaticResource SettingsSegment}"
                                                                 IsChecked="{Binding ImageGenerationPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=Approval}" />
                                                    <RadioButton Content="完全"
                                                                 GroupName="ImageGenPermMode"
                                                                 Style="{StaticResource SettingsSegment}"
                                                                 IsChecked="{Binding ImageGenerationPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=FullAccess}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <Border Style="{StaticResource SettingsRowDivider}" />
                                        <!-- Vision -->
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="视觉理解" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Style="{StaticResource SettingsSegmentTrack}">
                                                <StackPanel Orientation="Horizontal">
                                                    <RadioButton Content="审批"
                                                                 GroupName="VisionPermMode"
                                                                 Style="{StaticResource SettingsSegment}"
                                                                 IsChecked="{Binding VisionPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=Approval}" />
                                                    <RadioButton Content="完全"
                                                                 GroupName="VisionPermMode"
                                                                 Style="{StaticResource SettingsSegment}"
                                                                 IsChecked="{Binding VisionPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=FullAccess}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <Border Style="{StaticResource SettingsRowDivider}" />
                                        <!-- MCP -->
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="MCP 工具" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Style="{StaticResource SettingsSegmentTrack}">
                                                <StackPanel Orientation="Horizontal">
                                                    <RadioButton Content="审批"
                                                                 GroupName="McpPermMode"
                                                                 Style="{StaticResource SettingsSegment}"
                                                                 IsChecked="{Binding McpPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=Approval}" />
                                                    <RadioButton Content="完全"
                                                                 GroupName="McpPermMode"
                                                                 Style="{StaticResource SettingsSegment}"
                                                                 IsChecked="{Binding McpPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=FullAccess}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <Border Style="{StaticResource SettingsRowDivider}" />
                                        <!-- Python -->
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="Python 执行" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Style="{StaticResource SettingsSegmentTrack}">
                                                <StackPanel Orientation="Horizontal">
                                                    <RadioButton Content="审批"
                                                                 GroupName="PythonPermMode"
                                                                 Style="{StaticResource SettingsSegment}"
                                                                 IsChecked="{Binding PythonExecutionPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=Approval}" />
                                                    <RadioButton Content="完全"
                                                                 GroupName="PythonPermMode"
                                                                 Style="{StaticResource SettingsSegment}"
                                                                 IsChecked="{Binding PythonExecutionPermissionMode, Converter={StaticResource EnumEq}, ConverterParameter=FullAccess}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <TextBlock Style="{StaticResource SettingsRowHint}"
                                                   Margin="0,8,0,2"
                                                   Text="完全权限跳过普通审批；破坏性操作除外；全局设为完全权限时此处设置不生效。" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="Python 执行 — 放行与拦截规则" />
                                <Border Style="{StaticResource SettingsCard}" IsEnabled="{Binding PythonToolEnabled}">
                                    <StackPanel Margin="16,14">
                                        <TextBlock Style="{StaticResource SettingsRowHint}"
                                                   Margin="0,0,0,12"
                                                   Text="这些规则叠加在审批之上：仅用「额外允许导入」内的模块且无风险时自动放行；命中「禁止导入」或「禁止路径前缀」时直接拦截（完全权限模式下也拦截）。每行或逗号分隔一项。" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="额外允许导入" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             MinHeight="54" TextWrapping="Wrap" AcceptsReturn="True"
                                                             Text="{Binding PythonToolAllowedImports, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="禁止导入" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             MinHeight="54" TextWrapping="Wrap" AcceptsReturn="True"
                                                             Text="{Binding PythonToolDeniedImports, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="允许路径前缀" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             MinHeight="54" TextWrapping="Wrap" AcceptsReturn="True"
                                                             Text="{Binding PythonToolAllowedPathPrefixes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="禁止路径前缀" />
                                                <Border Background="{DynamicResource Brush.Bg.Secondary}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             MinHeight="54" TextWrapping="Wrap" AcceptsReturn="True"
                                                             Text="{Binding PythonToolDeniedPathPrefixes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="MCP 服务器">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,26" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="MCP 服务器" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}"
                                           Text="接入 Model Context Protocol 服务器，为对话扩展外部工具。仅支持 HTTP (Streamable HTTP) 类型。" />

                                <Grid Margin="2,4,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0"
                                               Style="{StaticResource SettingsSectionLabel}" Text="已连接的服务器" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource OutlineButton}"
                                            Content="添加服务器"
                                            Padding="14,7"
                                            VerticalAlignment="Center"
                                            Click="AddMcpServerClick" />
                                </Grid>

                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="8">
                                                <TextBlock x:Name="McpEmptyHint"
                                                           Text="尚未添加任何 MCP 服务器"
                                                           Margin="10,18"
                                                           HorizontalAlignment="Center"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                                <ItemsControl x:Name="McpServersList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Padding="12,9"
                                                                    Margin="0,0,0,4">
                                                                <Border.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="复制服务器名称"
                                                                                  CommandParameter="{Binding PlacementTarget.DataContext.Name, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  Click="CopyTextMenuItem_Click" />
                                                                        <MenuItem Header="复制服务器地址"
                                                                                  CommandParameter="{Binding PlacementTarget.DataContext.Url, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  Click="CopyTextMenuItem_Click" />
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Ellipse Grid.Column="0"
                                                                             Width="8" Height="8"
                                                                             Margin="0,0,10,0"
                                                                             VerticalAlignment="Center">
                                                                        <Ellipse.Style>
                                                                            <Style TargetType="Ellipse">
                                                                                <Setter Property="Fill" Value="{DynamicResource Brush.Text.Muted}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Ellipse.Style>
                                                                    </Ellipse>
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="{DynamicResource Font.Size.Small}"
                                                                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                                                                        <TextBlock Text="{Binding Url}"
                                                                                   FontSize="{DynamicResource Font.Size.XSmall}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                                                   Margin="0,2,0,0" />
                                                                    </StackPanel>
                                                                    <Button Grid.Column="2"
                                                                            Style="{StaticResource InlineActionButton}"
                                                                            Margin="4,0,0,0"
                                                                            ToolTip="编辑"
                                                                            Tag="{Binding}"
                                                                            Click="EditMcpServerClick">
                                                                        <TextBlock Text="&#xE70F;" FontFamily="{DynamicResource Font.Icon}" FontSize="13" />
                                                                    </Button>
                                                                    <Button Grid.Column="3"
                                                                            Style="{StaticResource InlineActionButton}"
                                                                            Margin="2,0,0,0"
                                                                            ToolTip="删除"
                                                                            Tag="{Binding}"
                                                                            Click="DeleteMcpServerClick">
                                                                        <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource Font.Icon}" FontSize="13" />
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                    </Grid>
                                </Border>

                                <Border Background="{DynamicResource Brush.Primary.Tint}"
                                        BorderBrush="{DynamicResource Brush.Primary.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="12,10">
                                    <TextBlock Style="{StaticResource SettingsRowHint}" Margin="0"
                                               Text="MCP 服务器对支持工具调用的自定义模型可用。" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="技能"
                             Visibility="{Binding PythonToolEnabled, Converter={StaticResource BoolVis}}">
                        <DockPanel Margin="24,20">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="技能" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}" Text="管理内置与自定义技能，对话中按需使用。" />
                            </StackPanel>
                            <Grid x:Name="SkillsTabRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: skill list + action bar -->
                            <Border Grid.Column="0"
                                    BorderBrush="{DynamicResource Brush.Divider}"
                                    BorderThickness="0,0,1,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="技能让模型用本地 Python 完成结构化任务（需开启 Python 工具）。"
                                               TextWrapping="Wrap"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               Margin="16,16,16,8" />

                                    <ListBox Grid.Row="1"
                                             x:Name="SkillsList"
                                             ItemsSource="{Binding Skills}"
                                             SelectionChanged="SkillSelectionChanged"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="8,4"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,2" />
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="row"
                                                                    Background="Transparent"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Padding="10,8">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="row" Property="Background"
                                                                            Value="{DynamicResource Brush.Bg.HoverOverlay}" />
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="row" Property="Background"
                                                                            Value="{DynamicResource Brush.Primary.Soft}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,10,0" />
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                                                            <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Padding="6,1"
                                                                    Margin="8,0,0,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding SourceLabel}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}"
                                                                   TextWrapping="Wrap"
                                                                   MaxHeight="48"
                                                                   FontSize="{DynamicResource Font.Size.Small}"
                                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel Grid.Row="2" Margin="12,8,12,12">
                                        <Button Click="ImportSkillClick"
                                                Style="{StaticResource OutlineButton}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                Padding="0,8"
                                                Margin="0,0,0,6"
                                                Content="导入技能…" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Click="OpenSkillsDirectoryClick"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="12,6"
                                                    Margin="0,0,6,0"
                                                    FontSize="{DynamicResource Font.Size.Small}"
                                                    Content="打开技能目录" />
                                            <Button Click="RefreshSkillsClick"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="12,6"
                                                    FontSize="{DynamicResource Font.Size.Small}"
                                                    Content="刷新" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Right: selected skill detail -->
                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                          DataContext="{Binding SelectedItem, ElementName=SkillsList}">
                                <Grid Margin="24">
                                    <TextBlock Text="从左侧选择一个技能查看详情。"
                                               Foreground="{DynamicResource Brush.Text.Muted}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                                            <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="8,2"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SourceLabel}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                            </Border>
                                        </StackPanel>

                                        <CheckBox Content="在对话中启用此技能"
                                                  IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                  Foreground="{DynamicResource Brush.Text.Secondary}"
                                                  Margin="0,12,0,0" />

                                        <TextBlock Text="描述" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   Margin="0,16,0,4" />
                                        <TextBlock Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource Brush.Text.Primary}" />

                                        <TextBlock Text="技能目录" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   Margin="0,16,0,4" />
                                        <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                Padding="12,8">
                                            <TextBox Text="{Binding DirectoryPath, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource InlineTextBox}"
                                                     TextWrapping="Wrap" />
                                        </Border>

                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button Click="ViewSkillMdClick"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="12,6"
                                                    Margin="0,0,8,0"
                                                    Content="查看 SKILL.md" />
                                            <Button x:Name="DeleteSkillButton"
                                                    Click="DeleteSkillClick"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="12,6"
                                                    Content="删除"
                                                    Visibility="Collapsed" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
