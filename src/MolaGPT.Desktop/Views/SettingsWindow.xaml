<Window x:Class="MolaGPT.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MolaGPT.ViewModels;assembly=MolaGPT.ViewModels"
        xmlns:views="clr-namespace:MolaGPT.Desktop.Views"
        xmlns:ctl="clr-namespace:MolaGPT.Desktop.Controls"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        Title="设置 — MolaGPT"
        Icon="/Assets/app-logo.png"
        Width="1040" Height="740"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="{DynamicResource Font.Cjk}"
        FontSize="{DynamicResource Font.Size.Body}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        mc:Ignorable="d">

    <Window.Resources>
        <!-- ===== Settings design system (mirrors docs/settings-redesign-demo) ===== -->
        <Style x:Key="SettingsPageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Title}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        </Style>
        <Style x:Key="SettingsPageSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Small}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,6,0,18" />
        </Style>
        <Style x:Key="SettingsSectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Small}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
            <Setter Property="Margin" Value="2,22,2,8" />
        </Style>
        <Style x:Key="SettingsRowTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        </Style>
        <Style x:Key="SettingsRowHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Small}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="SettingsFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Small}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Bg.Tertiary}" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Md}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="SettingsRowDivider" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Brush.Divider}" />
            <Setter Property="Margin" Value="16,0" />
        </Style>

        <!-- Toggle switch (extracted from the account sync toggle) -->
        <Style x:Key="SettingsToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="46" Height="26" CornerRadius="13"
                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                                Background="{DynamicResource Brush.Bg.Secondary}">
                            <Border x:Name="Thumb" Width="20" Height="18" Margin="3"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    CornerRadius="7" Background="{DynamicResource Brush.Bg.Elevated}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#66000000" BlurRadius="3" ShadowDepth="1" Opacity="0.35" />
                                </Border.Effect>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource Brush.Primary}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource Brush.Primary}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented control: RadioButtons rendered as a pill group -->
        <Style x:Key="SettingsSegment" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="15,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="{DynamicResource Radius.Sm}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.Primary}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnPrimary}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsSegmentTrack" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Bg.Secondary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Md}" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <!-- Quick-insert variable chip (persona prompt editor) -->
        <Style x:Key="SettingsVarChip" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Primary}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Small}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{DynamicResource Brush.Bg.Secondary}"
                                BorderBrush="{DynamicResource Brush.Primary.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Sm}"
                                Padding="9,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.Primary.Soft}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Border CornerRadius="{DynamicResource Radius.Xl}"
                BorderBrush="{DynamicResource Brush.Primary.Border}"
                BorderThickness="1"
                Opacity="0.85"
                IsHitTestVisible="False"
                Margin="-2">
            <Border.Effect>
                <DropShadowEffect Color="#FFBE727F"
                                  BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.18" />
            </Border.Effect>
        </Border>
        <Border Background="{DynamicResource Brush.Bg.Elevated}"
                CornerRadius="{DynamicResource Radius.Xl}"
                BorderBrush="{DynamicResource Brush.Border.Strong}"
                BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect Color="#FF000000"
                                  BlurRadius="48"
                                  ShadowDepth="10"
                                  Direction="270"
                                  Opacity="0.28" />
            </Border.Effect>
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        Padding="24,18"
                        BorderBrush="{DynamicResource Brush.Divider}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="HeaderMouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="设置"
                                   FontSize="{DynamicResource Font.Size.Title}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource HeaderIconButton}"
                                Click="CloseClick"
                                ToolTip="关闭">
                            <TextBlock Text="&#xE711;" FontFamily="{DynamicResource Font.Icon}" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>

                <TabControl x:Name="SettingsTabs"
                            TabStripPlacement="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0">
                    <TabControl.Resources>
                        <!-- Sidebar group header: a non-interactive label that
                             separates the nav items into sections. It is itself a
                             (disabled) TabItem so TabControl.Items stays homogeneous;
                             code-behind iterates with .OfType<TabItem>() and matches
                             by Header, so these never get selected or navigated to. -->
                        <Style x:Key="NavGroupHeader" TargetType="TabItem">
                            <Setter Property="IsEnabled" Value="False" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <TextBlock Text="{TemplateBinding Header}"
                                                   Margin="12,16,12,6"
                                                   FontSize="{DynamicResource Font.Size.XSmall}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Muted}" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <!-- Sidebar nav item -->
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                            <Setter Property="FontWeight" Value="Normal" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="b"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="{DynamicResource Radius.Md}"
                                                Padding="12,9"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter ContentSource="Header"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.Bg.HoverOverlay}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.Primary.Soft}" />
                                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Brush.Primary.Border}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Primary}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- Shell: left sidebar (vertical items host) + content area -->
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="208" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{DynamicResource Brush.Bg.Secondary}"
                                        BorderBrush="{DynamicResource Brush.Divider}"
                                        BorderThickness="0,0,1,0"
                                        CornerRadius="0,0,0,18">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Padding="10,8,10,16">
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                                <Border Grid.Column="1" Background="Transparent">
                                    <ContentPresenter ContentSource="SelectedContent" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </TabControl.Template>

                    <!-- ===== 通用 ===== -->
                    <TabItem Header="通用" Style="{StaticResource NavGroupHeader}" />
                    <TabItem Header="账号与同步" IsSelected="True">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,26" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="账号与同步" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}"
                                           Text="登录后可在桌面端使用网页端同款模型、对话同步与个性化能力。" />

                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <TextBlock x:Name="StatusLine" Style="{StaticResource SettingsRowTitle}" />
                                            <TextBlock x:Name="StatusDetail" Style="{StaticResource SettingsRowHint}" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Button x:Name="LoginLogoutButton" Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource OutlineButton}"
                                                Padding="14,7"
                                                Click="LoginLogoutClick" />
                                    </Grid>
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="数据同步" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel>
                                        <Grid Margin="16,13">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="对话云同步" />
                                                <TextBlock Style="{StaticResource SettingsRowHint}"
                                                           Text="开启后，本机的对话会与 MolaGPT 网页端双向同步，自定义 API 的对话不会被上传。" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource SettingsToggle}"
                                                          IsEnabled="{Binding IsLoggedIn}"
                                                          IsChecked="{Binding SyncConversations, Mode=TwoWay}"
                                                          Checked="SyncToggleChanged"
                                                          Unchecked="SyncToggleChanged" />
                                        </Grid>
                                        <Border Style="{StaticResource SettingsRowDivider}" />
                                        <Grid Margin="16,13">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="CloudSyncStatusText" Grid.Column="0"
                                                       VerticalAlignment="Center" Margin="0,0,16,0"
                                                       Style="{StaticResource SettingsRowHint}" />
                                            <Button x:Name="SyncNowButton" Grid.Column="1"
                                                    Style="{StaticResource OutlineButton}"
                                                    Content="立即同步"
                                                    Padding="12,6"
                                                    IsEnabled="{Binding IsLoggedIn}"
                                                    Click="SyncNowClick" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="个性化 · MolaGPT Tracks" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingsRowTitle}" Text="启用个性化记忆" />
                                            <TextBlock Style="{StaticResource SettingsRowHint}"
                                                       Text="MolaGPT 会从对话中学习你的偏好，让后续回复更贴合你的需求。关闭后不会记录任何个性化数据，仅在登录 MolaGPT 账号时生效。" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource SettingsToggle}"
                                                      IsChecked="{Binding TracksEnabled}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="界面与偏好">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,26" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="界面与偏好" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}"
                                           Text="调整外观、输入习惯与系统集成方式。" />

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Margin="2,4,2,8" Text="外观" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingsRowTitle}" Text="主题" />
                                            <TextBlock Style="{StaticResource SettingsRowHint}" Text="跟随系统会随 Windows 的明暗设置自动切换。" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource SettingsSegmentTrack}" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="ThemeSystem" Content="跟随系统" GroupName="theme"
                                                             Style="{StaticResource SettingsSegment}"
                                                             IsChecked="{Binding ThemeMode, Converter={StaticResource EnumEq}, ConverterParameter=System}" />
                                                <RadioButton x:Name="ThemeLight" Content="浅色" GroupName="theme"
                                                             Style="{StaticResource SettingsSegment}"
                                                             IsChecked="{Binding ThemeMode, Converter={StaticResource EnumEq}, ConverterParameter=Light}" />
                                                <RadioButton x:Name="ThemeDark" Content="深色" GroupName="theme"
                                                             Style="{StaticResource SettingsSegment}"
                                                             IsChecked="{Binding ThemeMode, Converter={StaticResource EnumEq}, ConverterParameter=Dark}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="输入" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingsRowTitle}" Text="按 Enter 直接发送消息" />
                                            <TextBlock Style="{StaticResource SettingsRowHint}" Text="关闭时 Enter 换行，Ctrl+Enter 发送；开启时 Shift+Enter 仍可换行。" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding EnterToSend}" />
                                    </Grid>
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="通知与系统集成" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel>
                                        <Grid Margin="16,13">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="后台回答完成时通知" />
                                                <TextBlock Style="{StaticResource SettingsRowHint}" Text="窗口最小化或切换到其它对话时，回答完成会弹出系统通知。" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding EnableCompletionNotification}" />
                                        </Grid>
                                        <Border Style="{StaticResource SettingsRowDivider}" />
                                        <Grid Margin="16,13">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="启用系统托盘" />
                                                <TextBlock Style="{StaticResource SettingsRowHint}" Text="关闭窗口时可最小化到托盘而非退出。" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding EnableTrayIcon}" />
                                        </Grid>
                                        <StackPanel Visibility="{Binding EnableTrayIcon, Converter={StaticResource BoolVis}}">
                                            <Border Style="{StaticResource SettingsRowDivider}" />
                                            <StackPanel Margin="16,13">
                                                <TextBlock Style="{StaticResource SettingsRowTitle}" Text="关闭按钮行为" Margin="0,0,0,6" />
                                                <RadioButton Content="最小化到托盘" GroupName="trayClose" Margin="0,4"
                                                             Foreground="{DynamicResource Brush.Text.Primary}"
                                                             IsChecked="{Binding TrayCloseBehavior, Converter={StaticResource EnumEq}, ConverterParameter=MinimizeToTray}" />
                                                <RadioButton Content="关闭软件" GroupName="trayClose" Margin="0,4"
                                                             Foreground="{DynamicResource Brush.Text.Primary}"
                                                             IsChecked="{Binding TrayCloseBehavior, Converter={StaticResource EnumEq}, ConverterParameter=Exit}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <!-- ===== 模型 ===== -->
                    <TabItem Header="模型" Style="{StaticResource NavGroupHeader}" />
                    <TabItem Header="模型服务">
                        <DockPanel Margin="24,20">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="模型服务" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}" Text="添加自定义 API（OpenAI 兼容 / Anthropic / Gemini），密钥经 DPAPI 加密保存在本机。" />
                            </StackPanel>
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <DockPanel.Resources>
                                    <CollectionViewSource x:Key="GroupedProviders"
                                                          Source="{Binding Providers}">
                                        <CollectionViewSource.GroupDescriptions>
                                            <PropertyGroupDescription PropertyName="Purpose" />
                                        </CollectionViewSource.GroupDescriptions>
                                    </CollectionViewSource>
                                </DockPanel.Resources>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource PillPrimaryButton}"
                                            Content="+ 对话服务"
                                            Click="AddChatProviderClick" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource OutlineButton}"
                                            Content="+ 图像服务"
                                            Click="AddImageProviderClick" />
                                </Grid>
                                <ListBox x:Name="ProviderList"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ItemContainerStyle="{StaticResource ConversationListItemStyle}"
                                         SelectionChanged="ProviderList_SelectionChanged"
                                         ItemsSource="{Binding Source={StaticResource GroupedProviders}}">
                                    <ListBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name, Converter={x:Static views:PurposeToGroupLabelConverter.Instance}}"
                                                               FontSize="{DynamicResource Font.Size.Small}"
                                                               FontWeight="SemiBold"
                                                               Margin="2,10,0,4"
                                                               Foreground="{DynamicResource Brush.Text.Muted}" />
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ListBox.GroupStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ProviderEntry}">
                                            <StackPanel>
                                                <StackPanel.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="复制服务名称"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext.Name, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  Click="CopyTextMenuItem_Click" />
                                                    </ContextMenu>
                                                </StackPanel.ContextMenu>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                                <TextBlock Text="{Binding Type, Converter={x:Static views:ProviderTypeToLabelConverter.Instance}}"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ProviderEditor" IsEnabled="False">
                                    <TextBlock Text="自定义模型服务"
                                               FontSize="{DynamicResource Font.Size.Heading}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Primary}" />
                                    <TextBlock Text="接入您自己的 OpenAI、Claude、Gemini 或兼容服务。填入 API Key 后可自动获取模型列表。"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,16"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Muted}" />

                                    <!-- 基本信息分组 -->
                                    <TextBlock Text="服务信息"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               Margin="0,0,0,8" />
                                    <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="16,14"
                                            Margin="0,0,0,20"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="1">
                                        <StackPanel>

                                    <TextBlock Text="快速填充" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <ComboBox x:Name="ProviderPresetCombo"
                                              Style="{StaticResource SettingsComboBox}"
                                              Margin="0,0,0,12"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="ProviderPresetCombo_SelectionChanged" />

                                    <TextBlock Text="名称" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="12,8" Margin="0,0,0,12">
                                        <TextBox x:Name="EditName" Style="{StaticResource InlineTextBox}" />
                                    </Border>

                                    <StackPanel x:Name="TypePanel">
                                    <TextBlock Text="协议格式" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                        <ComboBox x:Name="EditType"
                                                  Style="{StaticResource SettingsComboBox}"
                                                  Margin="0,0,0,12">
                                        <ComboBoxItem Content="OpenAI 兼容" Tag="openai-compat" />
                                        <ComboBoxItem Content="Claude" Tag="anthropic" />
                                        <ComboBoxItem Content="Gemini" Tag="gemini" />
                                        <ComboBoxItem Content="OpenAI Responses" Tag="openai-response" />
                                    </ComboBox>
                                    </StackPanel>

                                    <TextBlock Text="接入地址" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="12,8" Margin="0,0,0,12">
                                        <TextBox x:Name="EditBaseUrl"
                                                 Style="{StaticResource InlineTextBox}"
                                                 TextChanged="EndpointInputChanged" />
                                    </Border>

                                    <!-- API 路径 (对话: chat/completions; 图像: 生成路径) -->
                                    <TextBlock x:Name="ApiPathLabel" Text="对话路径" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="12,8" Margin="0,0,0,12">
                                        <TextBox x:Name="EditApiPath"
                                                 Style="{StaticResource InlineTextBox}"
                                                 TextChanged="EndpointInputChanged" />
                                    </Border>

                                    <!-- 图像接口格式 + 编辑路径 (仅图像服务) -->
                                    <StackPanel x:Name="ImageFormatPanel" Visibility="Collapsed">
                                        <TextBlock Text="接口格式" Margin="0,0,0,4"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}" />
                                        <ComboBox x:Name="EditImageFormat"
                                                  Style="{StaticResource SettingsComboBox}"
                                                  Margin="0,0,0,12"
                                                  SelectionChanged="ImageFormatChanged">
                                            <ComboBoxItem Content="OpenAI 图像接口（DALL·E、gpt-image）" Tag="openai-images" />
                                            <ComboBoxItem Content="对话补全出图（OpenRouter、nano-banana）" Tag="openai-chat-image" />
                                        </ComboBox>

                                        <StackPanel x:Name="ImageEditPathPanel">
                                            <TextBlock Text="编辑路径" Margin="0,0,0,4"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}" />
                                            <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="12,8" Margin="0,0,0,12">
                                                <TextBox x:Name="EditImageEditPath"
                                                         Style="{StaticResource InlineTextBox}"
                                                         TextChanged="EndpointInputChanged" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 最终端点预览 -->
                                    <TextBlock x:Name="EndpointPreview" Margin="0,0,0,12"
                                               TextWrapping="Wrap"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Muted}">
                                        <TextBlock.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="复制请求地址"
                                                          CommandParameter="{Binding PlacementTarget.Text, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Click="CopyTextMenuItem_Click" />
                                            </ContextMenu>
                                        </TextBlock.ContextMenu>
                                    </TextBlock>

                                    <TextBlock Text="API Key" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="12,8" Margin="0,0,0,0">
                                        <ctl:RevealableSecretBox x:Name="EditApiKey" />
                                    </Border>

                                        </StackPanel>
                                    </Border>

                                    <!-- 模型管理分组 -->
                                    <TextBlock Text="模型"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               Margin="0,0,0,8" />

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="可用模型"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   VerticalAlignment="Center" />
                                        <Button x:Name="DetectModelsButton"
                                                Grid.Column="1"
                                                Style="{StaticResource OutlineButton}"
                                                Content="自动获取"
                                                Padding="12,6"
                                                Margin="0,0,8,0"
                                                Click="DetectModelsClick" />
                                        <Button x:Name="AddModelButton"
                                                Grid.Column="2"
                                                Style="{StaticResource OutlineButton}"
                                                Content="+ 手动添加"
                                                Padding="12,6"
                                                Click="AddModelClick" />
                                    </Grid>
                                    <ItemsControl x:Name="ModelCards"
                                                  Margin="0,8,0,16">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type views:EditableModelEntry}">
                                                <Border Style="{StaticResource ModelCardBorder}"
                                                        Margin="0,0,0,6"
                                                        MouseLeftButtonDown="ModelCard_Click">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="复制模型 ID"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      Click="CopyTextMenuItem_Click" />
                                                            <MenuItem Header="复制显示名称"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext.DisplayName, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      Click="CopyTextMenuItem_Click" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Id}"
                                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                                                <TextBlock Text=" · "
                                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                                           Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                            </StackPanel>
                                                            <ItemsControl ItemsSource="{Binding CapabilityBadges}"
                                                                          Margin="0,5,0,0">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{Binding ColorKey, Converter={x:Static views:BadgeBackgroundConverter.Instance}}"
                                                                                CornerRadius="3"
                                                                                Padding="6,2"
                                                                                Margin="0,0,4,0"
                                                                                Opacity="0.85">
                                                                            <TextBlock Text="{Binding Label}"
                                                                                       FontSize="10"
                                                                                       Foreground="{Binding ColorKey, Converter={x:Static views:BadgeForegroundConverter.Instance}}" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Style="{StaticResource HeaderIconButton}"
                                                                Click="RemoveModelClick"
                                                                ToolTip="删除模型"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="&#xE711;"
                                                                       FontFamily="{DynamicResource Font.Icon}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Brush.Text.Muted}" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <DockPanel LastChildFill="False">
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource PillPrimaryButton}"
                                                Content="保存"
                                                Width="100"
                                                Click="SaveProviderClick" />
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource OutlineButton}"
                                                Content="测试连接"
                                                Width="120"
                                                Margin="0,0,8,0"
                                                Click="TestProviderClick" />
                                        <Button DockPanel.Dock="Left"
                                                Style="{StaticResource OutlineButton}"
                                                Content="删除服务"
                                                Width="100"
                                                Click="DeleteProviderClick" />
                                    </DockPanel>

                                    <TextBlock x:Name="EditorMessage"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                               FontSize="{DynamicResource Font.Size.Small}" />
                                </StackPanel>
                            </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                    <TabItem x:Name="PersonaTab" Header="角色">
                        <DockPanel Margin="24,20">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="角色" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}" Text="为不同场景定义系统提示与默认行为，发起对话时一键切换。" />
                            </StackPanel>
                            <Grid x:Name="PersonaTabRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: list + actions -->
                            <Border Grid.Column="0"
                                    BorderBrush="{DynamicResource Brush.Divider}"
                                    BorderThickness="0,0,1,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- New button -->
                                    <Button Grid.Row="0"
                                            Click="NewPersonaClick"
                                            Style="{StaticResource OutlineButton}"
                                            Margin="16,16,16,8"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="0,8">
                                        <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                            <TextBlock Text="&#xE710;"
                                                       Style="{StaticResource InlineIconTextBlock.Small}"
                                                       FontSize="12"
                                                       Margin="0,0,6,0" />
                                            <TextBlock Text="新建角色"
                                                       Style="{StaticResource InlineTextBlock.Small}" />
                                        </StackPanel>
                                    </Button>

                                    <!-- List -->
                                    <ListBox Grid.Row="1"
                                             x:Name="PersonaList"
                                             ItemsSource="{Binding Personas}"
                                             SelectionChanged="PersonaSelectionChanged"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="8,4"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,2" />
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="row"
                                                                    Background="Transparent"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Padding="10,8">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="row" Property="Background"
                                                                            Value="{DynamicResource Brush.Bg.HoverOverlay}" />
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="row" Property="Background"
                                                                            Value="{DynamicResource Brush.Primary.Soft}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding DisplayAvatar}"
                                                               FontFamily="{DynamicResource Font.Icon}"
                                                               FontSize="16"
                                                               Width="28"
                                                               TextAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Preview}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <!-- Lock icon for built-in personas -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="&#xE72E;"
                                                               FontFamily="{DynamicResource Font.Icon}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0"
                                                               ToolTip="内置角色，可复制后编辑"
                                                               Visibility="{Binding IsBuiltin, Converter={x:Static views:BoolToVisibility.Instance}}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Bottom actions -->
                                    <Border Grid.Row="2"
                                            BorderBrush="{DynamicResource Brush.Divider}"
                                            BorderThickness="0,1,0,0"
                                            Padding="12,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="DuplicatePersonaButton"
                                                    Content="复制"
                                                    Click="DuplicatePersonaClick"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="14,5"
                                                    Margin="0,0,8,0" />
                                            <Button x:Name="DeletePersonaButton"
                                                    Content="删除"
                                                    Click="DeletePersonaClick"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="14,5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Right: editor panel -->
                            <Grid Grid.Column="1">
                                <TextBlock x:Name="PersonaEmptyHint"
                                           Text="选择左侧角色以编辑，或新建一个角色。"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PersonaEditPanel" Margin="32,24,32,24">
                                        <TextBlock x:Name="BuiltinLockHint"
                                                   Text="此为内置角色，字段已锁定。点击下方“复制”按钮基于它创建一个可编辑副本。"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Background="{DynamicResource Brush.Primary.Soft}"
                                                   Foreground="{DynamicResource Brush.Primary.Hover}"
                                                   Padding="12,8"
                                                   Margin="0,0,0,16"
                                                   Visibility="Collapsed" />

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="角色名称"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           Margin="0,0,0,4" />
                                                <Border Background="{DynamicResource Brush.Bg.Primary}"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="10,8">
                                                    <TextBox x:Name="PersonaNameBox"
                                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource SettingsTextBox}"
                                                             FontSize="14"
                                                             LostFocus="PersonaFormChanged" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Avatar picker: monochrome Fluent
                                             icons, one click toggles the
                                             persona's stored glyph. We don't
                                             accept free-form input because the
                                             rest of the desktop uses the same
                                             icon family (no emoji). -->
                                        <TextBlock Text="头像图标"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   Margin="0,0,0,4" />
                                        <ItemsControl x:Name="PersonaIconPicker"
                                                      Margin="0,0,0,14">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Click="OnPersonaIconClick"
                                                            Tag="{Binding Glyph}"
                                                            ToolTip="{Binding Label}"
                                                            Cursor="Hand"
                                                            Margin="0,0,6,6"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Padding="0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="cell"
                                                                        Width="36" Height="36"
                                                                        Background="{DynamicResource Brush.Bg.Tertiary}"
                                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="{DynamicResource Radius.Sm}">
                                                                    <TextBlock Text="{Binding Glyph}"
                                                                               FontFamily="{DynamicResource Font.Icon}"
                                                                               FontSize="16"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{DynamicResource Brush.Text.Primary}" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="cell" Property="BorderBrush"
                                                                                Value="{DynamicResource Brush.Primary.Border}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="系统提示词"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   Margin="0,0,0,4" />
                                        <Border Background="{DynamicResource Brush.Bg.Primary}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                Padding="12,10"
                                                Height="280"
                                                Margin="0,0,0,4">
                                            <TextBox x:Name="PersonaPromptBox"
                                                     Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SettingsTextBox}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     FontSize="13"
                                                     LostFocus="PersonaFormChanged" />
                                        </Border>
                                        <WrapPanel Margin="0,2,0,2"
                                                   Visibility="{Binding IsEnabled, ElementName=PersonaPromptBox, Converter={StaticResource BoolVis}}">
                                            <TextBlock Text="插入变量"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       Margin="0,0,8,6" />
                                            <Button Style="{StaticResource SettingsVarChip}" Content="{}{{date}}" Tag="{}{{date}}" Click="InsertPromptVariableClick" />
                                            <Button Style="{StaticResource SettingsVarChip}" Content="{}{{time}}" Tag="{}{{time}}" Click="InsertPromptVariableClick" />
                                            <Button Style="{StaticResource SettingsVarChip}" Content="{}{{model}}" Tag="{}{{model}}" Click="InsertPromptVariableClick" />
                                            <Button Style="{StaticResource SettingsVarChip}" Content="{}{{provider}}" Tag="{}{{provider}}" Click="InsertPromptVariableClick" />
                                            <Button Style="{StaticResource SettingsVarChip}" Content="{}{{username}}" Tag="{}{{username}}" Click="InsertPromptVariableClick" />
                                        </WrapPanel>
                                        <TextBlock Text="支持变量 {{date}} {{time}} {{model}} {{provider}} {{username}} —— 在每次对话发送前会替换为实时值。"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,14" />

                                        <Expander Header="默认行为开关" Margin="0,8,0,0">
                                            <StackPanel x:Name="PersonaDefaultsPanel" Margin="0,8,0,0">
                                                <TextBlock Text="选中以使用此角色时强制开启对应能力；不选则使用工具栏当前值。"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,8" />
                                                <CheckBox Content="默认开启联网搜索"
                                                          IsChecked="{Binding DefaultEnableNetwork, Mode=TwoWay}"
                                                          Click="PersonaFormChanged"
                                                          Margin="0,0,0,4" />
                                                <CheckBox Content="默认开启网页阅读"
                                                          IsChecked="{Binding DefaultEnableWebFetch, Mode=TwoWay}"
                                                          Click="PersonaFormChanged"
                                                          Margin="0,0,0,4" />
                                                <CheckBox Content="默认开启推理"
                                                          IsChecked="{Binding DefaultThinking, Mode=TwoWay}"
                                                          Click="PersonaFormChanged"
                                                          Margin="0,0,0,4" />
                                            </StackPanel>
                                        </Expander>

                                        <DockPanel Margin="0,18,0,0" LastChildFill="False">
                                            <Button x:Name="SavePersonaButton"
                                                    DockPanel.Dock="Right"
                                                    Content="保存角色"
                                                    Click="SavePersonaClick"
                                                    Style="{StaticResource PillPrimaryButton}"
                                                    Width="112" />
                                        </DockPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                    <!-- ===== Harness 与环境 ===== -->
                    <TabItem Header="Harness 与环境" Style="{StaticResource NavGroupHeader}" />
                    <TabItem Header="联网搜索">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,26" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource SettingsPageTitle}" Text="联网搜索" />
                                <TextBlock Style="{StaticResource SettingsPageSubtitle}"
                                           Text="用于自定义模型的联网搜索能力，仅对支持工具调用的 BYOK 模型生效。" />

                                <TextBlock Style="{StaticResource SettingsSectionLabel}" Margin="2,4,2,8" Text="搜索服务" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid Margin="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
