<Window x:Class="MolaGPT.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MolaGPT.ViewModels;assembly=MolaGPT.ViewModels"
        xmlns:views="clr-namespace:MolaGPT.Desktop.Views"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        Title="设置 — MolaGPT"
        Icon="/Assets/app-logo.png"
        Width="820" Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="{DynamicResource Font.Cjk}"
        FontSize="{DynamicResource Font.Size.Body}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        mc:Ignorable="d">

    <Grid Margin="32">
        <Border CornerRadius="{DynamicResource Radius.Xl}"
                BorderBrush="{DynamicResource Brush.Primary.Border}"
                BorderThickness="1"
                Opacity="0.85"
                IsHitTestVisible="False"
                Margin="-2">
            <Border.Effect>
                <DropShadowEffect Color="#FFBE727F"
                                  BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.18" />
            </Border.Effect>
        </Border>
        <Border Background="{DynamicResource Brush.Bg.Elevated}"
                CornerRadius="{DynamicResource Radius.Xl}"
                BorderBrush="{DynamicResource Brush.Border.Strong}"
                BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect Color="#FF000000"
                                  BlurRadius="48"
                                  ShadowDepth="10"
                                  Direction="270"
                                  Opacity="0.28" />
            </Border.Effect>
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        Padding="24,18"
                        BorderBrush="{DynamicResource Brush.Divider}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="HeaderMouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="设置"
                                   FontSize="{DynamicResource Font.Size.Title}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource HeaderIconButton}"
                                Click="CloseClick"
                                ToolTip="关闭">
                            <TextBlock Text="&#xE711;" FontFamily="{DynamicResource Font.Icon}" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>

                <TabControl x:Name="SettingsTabs"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                            <Setter Property="Padding" Value="20,12" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Primary}" />
                                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Brush.Primary}" />
                                                <Setter TargetName="b" Property="BorderThickness" Value="0,0,0,2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- ===== Tab: 账号与同步 ===== -->
                    <TabItem Header="账号与同步">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Text="MolaGPT 账号"
                                           FontSize="{DynamicResource Font.Size.Heading}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"
                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                <TextBlock Foreground="{DynamicResource Brush.Text.Secondary}"
                                           Margin="0,0,0,16"
                                           TextWrapping="Wrap">
                                    登录后可在桌面端使用网页端同款模型、对话同步与个性化能力。
                                </TextBlock>

                                <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="16,14"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="StatusLine"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                                            <TextBlock x:Name="StatusDetail"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       FontSize="{DynamicResource Font.Size.Small}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Button x:Name="LoginLogoutButton"
                                                Grid.Column="1"
                                                Style="{StaticResource OutlineButton}"
                                                Padding="14,7"
                                                Click="LoginLogoutClick" />
                                    </Grid>
                                </Border>

                                <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="16,14"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="对话云同步"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                                            <TextBlock Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       FontSize="{DynamicResource Font.Size.Small}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"
                                                       Text="开启后，本机的对话会与 MolaGPT 网页端双向同步，自定义 API 的对话不会被上传。" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <ToggleButton Width="48"
                                                          Height="28"
                                                          Cursor="Hand"
                                                          HorizontalAlignment="Right"
                                                          IsEnabled="{Binding IsLoggedIn}"
                                                          IsChecked="{Binding SyncConversations, Mode=TwoWay}"
                                                          Checked="SyncToggleChanged"
                                                          Unchecked="SyncToggleChanged">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="Track"
                                                                Width="48"
                                                                Height="28"
                                                                CornerRadius="9"
                                                                BorderBrush="{DynamicResource Brush.Border}"
                                                                BorderThickness="1"
                                                                Background="{DynamicResource Brush.Bg.Secondary}">
                                                            <Border x:Name="Thumb"
                                                                    Width="22"
                                                                    Height="20"
                                                                    Margin="3"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    CornerRadius="7"
                                                                    Background="{DynamicResource Brush.Bg.Elevated}">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#66000000"
                                                                                      BlurRadius="3"
                                                                                      ShadowDepth="1"
                                                                                      Opacity="0.35" />
                                                                </Border.Effect>
                                                            </Border>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource Brush.Primary}" />
                                                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource Brush.Primary}" />
                                                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.45" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <Button x:Name="SyncNowButton"
                                                    Style="{StaticResource OutlineButton}"
                                                    Content="立即同步"
                                                    Padding="12,6"
                                                    Margin="0,10,0,0"
                                                    IsEnabled="{Binding IsLoggedIn}"
                                                    Click="SyncNowClick" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock x:Name="CloudSyncStatusText"
                                           Margin="4,-4,4,12"
                                           TextWrapping="Wrap"
                                           FontSize="{DynamicResource Font.Size.Small}"
                                           Foreground="{DynamicResource Brush.Text.Muted}" />

                                <TextBlock Text="MolaGPT Tracks"
                                           FontSize="{DynamicResource Font.Size.Heading}"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,12"
                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                <CheckBox Content="启用个性化记忆"
                                          Foreground="{DynamicResource Brush.Text.Primary}"
                                          IsChecked="{Binding TracksEnabled}" />
                                <TextBlock Text="MolaGPT 会从对话中学习你的偏好，让后续回复更贴合你的需求。关闭后不会记录任何个性化数据，仅在登录 MolaGPT 账号时生效。"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           FontSize="{DynamicResource Font.Size.Small}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Tab: 模型服务（自定义模型） ===== -->
                    <TabItem Header="模型服务">
                        <Grid Margin="24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <DockPanel.Resources>
                                    <CollectionViewSource x:Key="GroupedProviders"
                                                          Source="{Binding Providers}">
                                        <CollectionViewSource.GroupDescriptions>
                                            <PropertyGroupDescription PropertyName="Purpose" />
                                        </CollectionViewSource.GroupDescriptions>
                                    </CollectionViewSource>
                                </DockPanel.Resources>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource PillPrimaryButton}"
                                            Content="+ 对话服务"
                                            Click="AddChatProviderClick" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource OutlineButton}"
                                            Content="+ 图像服务"
                                            Click="AddImageProviderClick" />
                                </Grid>
                                <ListBox x:Name="ProviderList"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ItemContainerStyle="{StaticResource ConversationListItemStyle}"
                                         SelectionChanged="ProviderList_SelectionChanged"
                                         ItemsSource="{Binding Source={StaticResource GroupedProviders}}">
                                    <ListBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name, Converter={x:Static views:PurposeToGroupLabelConverter.Instance}}"
                                                               FontSize="{DynamicResource Font.Size.Small}"
                                                               FontWeight="SemiBold"
                                                               Margin="2,10,0,4"
                                                               Foreground="{DynamicResource Brush.Text.Muted}" />
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ListBox.GroupStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ProviderEntry}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                                <TextBlock Text="{Binding Type, Converter={x:Static views:ProviderTypeToLabelConverter.Instance}}"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ProviderEditor" IsEnabled="False">
                                    <TextBlock Text="自定义模型服务"
                                               FontSize="{DynamicResource Font.Size.Heading}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Primary}" />
                                    <TextBlock Text="接入你自己的 OpenAI、Claude、Gemini 或兼容服务。填入 API Key 后可自动获取模型列表，能力开关随每个模型单独保存。"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,16"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Muted}" />

                                    <!-- 基本信息分组 -->
                                    <TextBlock Text="服务信息"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               Margin="0,0,0,8" />
                                    <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="16,14"
                                            Margin="0,0,0,20"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="1">
                                        <StackPanel>

                                    <TextBlock Text="快速填充" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <ComboBox x:Name="ProviderPresetCombo"
                                              Style="{StaticResource SettingsComboBox}"
                                              Margin="0,0,0,12"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="ProviderPresetCombo_SelectionChanged" />

                                    <TextBlock Text="名称" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="12,8" Margin="0,0,0,12">
                                        <TextBox x:Name="EditName" Style="{StaticResource InlineTextBox}" />
                                    </Border>

                                    <StackPanel x:Name="TypePanel">
                                    <TextBlock Text="协议格式" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                        <ComboBox x:Name="EditType"
                                                  Style="{StaticResource SettingsComboBox}"
                                                  Margin="0,0,0,12">
                                        <ComboBoxItem Content="OpenAI 兼容" Tag="openai-compat" />
                                        <ComboBoxItem Content="Claude" Tag="anthropic" />
                                        <ComboBoxItem Content="Gemini" Tag="gemini" />
                                        <ComboBoxItem Content="OpenAI Responses" Tag="openai-response" />
                                    </ComboBox>
                                    </StackPanel>

                                    <TextBlock Text="接入地址" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="12,8" Margin="0,0,0,12">
                                        <TextBox x:Name="EditBaseUrl"
                                                 Style="{StaticResource InlineTextBox}"
                                                 TextChanged="EndpointInputChanged" />
                                    </Border>

                                    <!-- API 路径 (对话: chat/completions; 图像: 生成路径) -->
                                    <TextBlock x:Name="ApiPathLabel" Text="对话路径" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="12,8" Margin="0,0,0,12">
                                        <TextBox x:Name="EditApiPath"
                                                 Style="{StaticResource InlineTextBox}"
                                                 TextChanged="EndpointInputChanged" />
                                    </Border>

                                    <!-- 图像接口格式 + 编辑路径 (仅图像服务) -->
                                    <StackPanel x:Name="ImageFormatPanel" Visibility="Collapsed">
                                        <TextBlock Text="接口格式" Margin="0,0,0,4"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}" />
                                        <ComboBox x:Name="EditImageFormat"
                                                  Style="{StaticResource SettingsComboBox}"
                                                  Margin="0,0,0,12"
                                                  SelectionChanged="ImageFormatChanged">
                                            <ComboBoxItem Content="OpenAI 图像接口（DALL·E、gpt-image）" Tag="openai-images" />
                                            <ComboBoxItem Content="对话补全出图（OpenRouter、nano-banana）" Tag="openai-chat-image" />
                                        </ComboBox>

                                        <StackPanel x:Name="ImageEditPathPanel">
                                            <TextBlock Text="编辑路径" Margin="0,0,0,4"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}" />
                                            <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="12,8" Margin="0,0,0,12">
                                                <TextBox x:Name="EditImageEditPath"
                                                         Style="{StaticResource InlineTextBox}"
                                                         TextChanged="EndpointInputChanged" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 最终端点预览 -->
                                    <TextBlock x:Name="EndpointPreview" Margin="0,0,0,12"
                                               TextWrapping="Wrap"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Muted}" />

                                    <TextBlock Text="API Key" Margin="0,0,0,4"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="12,8" Margin="0,0,0,0">
                                        <PasswordBox x:Name="EditApiKey"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="{DynamicResource Brush.Text.Primary}"
                                                     FontFamily="{DynamicResource Font.UI}"
                                                     FontSize="{DynamicResource Font.Size.Body}" />
                                    </Border>

                                        </StackPanel>
                                    </Border>

                                    <!-- 模型管理分组 -->
                                    <TextBlock Text="模型"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               Margin="0,0,0,8" />

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="可用模型"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   VerticalAlignment="Center" />
                                        <Button x:Name="DetectModelsButton"
                                                Grid.Column="1"
                                                Style="{StaticResource OutlineButton}"
                                                Content="自动获取"
                                                Padding="12,6"
                                                Margin="0,0,8,0"
                                                Click="DetectModelsClick" />
                                        <Button x:Name="AddModelButton"
                                                Grid.Column="2"
                                                Style="{StaticResource OutlineButton}"
                                                Content="+ 手动添加"
                                                Padding="12,6"
                                                Click="AddModelClick" />
                                    </Grid>
                                    <ItemsControl x:Name="ModelCards"
                                                  Margin="0,8,0,16">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type views:EditableModelEntry}">
                                                <Border Style="{StaticResource ModelCardBorder}"
                                                        Margin="0,0,0,6"
                                                        MouseLeftButtonDown="ModelCard_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Id}"
                                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                                                <TextBlock Text=" · "
                                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                                           Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                            </StackPanel>
                                                            <ItemsControl ItemsSource="{Binding CapabilityBadges}"
                                                                          Margin="0,5,0,0">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{Binding ColorKey, Converter={x:Static views:BadgeBackgroundConverter.Instance}}"
                                                                                CornerRadius="3"
                                                                                Padding="6,2"
                                                                                Margin="0,0,4,0"
                                                                                Opacity="0.85">
                                                                            <TextBlock Text="{Binding Label}"
                                                                                       FontSize="10"
                                                                                       Foreground="{Binding ColorKey, Converter={x:Static views:BadgeForegroundConverter.Instance}}" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Style="{StaticResource HeaderIconButton}"
                                                                Click="RemoveModelClick"
                                                                ToolTip="删除模型"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="&#xE711;"
                                                                       FontFamily="{DynamicResource Font.Icon}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Brush.Text.Muted}" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <DockPanel LastChildFill="False">
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource PillPrimaryButton}"
                                                Content="保存"
                                                Width="100"
                                                Click="SaveProviderClick" />
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource OutlineButton}"
                                                Content="测试连接"
                                                Width="120"
                                                Margin="0,0,8,0"
                                                Click="TestProviderClick" />
                                        <Button DockPanel.Dock="Left"
                                                Style="{StaticResource OutlineButton}"
                                                Content="删除服务"
                                                Width="100"
                                                Click="DeleteProviderClick" />
                                    </DockPanel>

                                    <TextBlock x:Name="EditorMessage"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                               FontSize="{DynamicResource Font.Size.Small}" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- ===== Tab: 角色 ===== -->
                    <TabItem x:Name="PersonaTab" Header="角色">
                        <Grid x:Name="PersonaTabRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: list + actions -->
                            <Border Grid.Column="0"
                                    BorderBrush="{DynamicResource Brush.Divider}"
                                    BorderThickness="0,0,1,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- New button -->
                                    <Button Grid.Row="0"
                                            Click="NewPersonaClick"
                                            Style="{StaticResource OutlineButton}"
                                            Margin="16,16,16,8"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE710;"
                                                       FontFamily="{DynamicResource Font.Icon}"
                                                       FontSize="12"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="新建角色" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <!-- List -->
                                    <ListBox Grid.Row="1"
                                             x:Name="PersonaList"
                                             ItemsSource="{Binding Personas}"
                                             SelectionChanged="PersonaSelectionChanged"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="8,4"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,2" />
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="row"
                                                                    Background="Transparent"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Padding="10,8">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="row" Property="Background"
                                                                            Value="{DynamicResource Brush.Bg.HoverOverlay}" />
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="row" Property="Background"
                                                                            Value="{DynamicResource Brush.Primary.Soft}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding DisplayAvatar}"
                                                               FontFamily="{DynamicResource Font.Icon}"
                                                               FontSize="16"
                                                               Width="28"
                                                               TextAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Preview}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <!-- Lock icon for built-in personas -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="&#xE72E;"
                                                               FontFamily="{DynamicResource Font.Icon}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0"
                                                               ToolTip="内置角色，可复制后编辑"
                                                               Visibility="{Binding IsBuiltin, Converter={x:Static views:BoolToVisibility.Instance}}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Bottom actions -->
                                    <Border Grid.Row="2"
                                            BorderBrush="{DynamicResource Brush.Divider}"
                                            BorderThickness="0,1,0,0"
                                            Padding="12,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="DuplicatePersonaButton"
                                                    Content="复制"
                                                    Click="DuplicatePersonaClick"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="14,5"
                                                    Margin="0,0,8,0" />
                                            <Button x:Name="DeletePersonaButton"
                                                    Content="删除"
                                                    Click="DeletePersonaClick"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="14,5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Right: editor panel -->
                            <Grid Grid.Column="1">
                                <TextBlock x:Name="PersonaEmptyHint"
                                           Text="选择左侧角色以编辑，或新建一个角色。"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PersonaEditPanel" Margin="32,24,32,24">
                                        <TextBlock x:Name="BuiltinLockHint"
                                                   Text="此为内置角色，字段已锁定。点击下方“复制”按钮基于它创建一个可编辑副本。"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Background="{DynamicResource Brush.Primary.Soft}"
                                                   Foreground="{DynamicResource Brush.Primary.Hover}"
                                                   Padding="12,8"
                                                   Margin="0,0,0,16"
                                                   Visibility="Collapsed" />

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="角色名称"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           Margin="0,0,0,4" />
                                                <Border Background="{DynamicResource Brush.Bg.Primary}"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="10,8">
                                                    <TextBox x:Name="PersonaNameBox"
                                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource SettingsTextBox}"
                                                             FontSize="14"
                                                             LostFocus="PersonaFormChanged" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Avatar picker: monochrome Fluent
                                             icons, one click toggles the
                                             persona's stored glyph. We don't
                                             accept free-form input because the
                                             rest of the desktop uses the same
                                             icon family (no emoji). -->
                                        <TextBlock Text="头像图标"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   Margin="0,0,0,4" />
                                        <ItemsControl x:Name="PersonaIconPicker"
                                                      Margin="0,0,0,14">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Click="OnPersonaIconClick"
                                                            Tag="{Binding Glyph}"
                                                            ToolTip="{Binding Label}"
                                                            Cursor="Hand"
                                                            Margin="0,0,6,6"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Padding="0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="cell"
                                                                        Width="36" Height="36"
                                                                        Background="{DynamicResource Brush.Bg.Tertiary}"
                                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="{DynamicResource Radius.Sm}">
                                                                    <TextBlock Text="{Binding Glyph}"
                                                                               FontFamily="{DynamicResource Font.Icon}"
                                                                               FontSize="16"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{DynamicResource Brush.Text.Primary}" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="cell" Property="BorderBrush"
                                                                                Value="{DynamicResource Brush.Primary.Border}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="系统提示词"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   Margin="0,0,0,4" />
                                        <Border Background="{DynamicResource Brush.Bg.Primary}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                Padding="12,10"
                                                Height="280"
                                                Margin="0,0,0,4">
                                            <TextBox x:Name="PersonaPromptBox"
                                                     Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SettingsTextBox}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     FontSize="13"
                                                     LostFocus="PersonaFormChanged" />
                                        </Border>
                                        <TextBlock Text="支持变量 {{date}} {{time}} {{model}} {{provider}} {{username}} —— 在每次对话发送前会替换为实时值。"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14" />

                                        <Expander Header="默认行为开关" Margin="0,8,0,0">
                                            <StackPanel x:Name="PersonaDefaultsPanel" Margin="0,8,0,0">
                                                <TextBlock Text="选中以使用此角色时强制开启对应能力；不选则使用工具栏当前值。"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,8" />
                                                <CheckBox Content="默认开启联网搜索"
                                                          IsChecked="{Binding DefaultEnableNetwork, Mode=TwoWay}"
                                                          Click="PersonaFormChanged"
                                                          Margin="0,0,0,4" />
                                                <CheckBox Content="默认开启网页阅读"
                                                          IsChecked="{Binding DefaultEnableWebFetch, Mode=TwoWay}"
                                                          Click="PersonaFormChanged"
                                                          Margin="0,0,0,4" />
                                                <CheckBox Content="默认开启推理"
                                                          IsChecked="{Binding DefaultThinking, Mode=TwoWay}"
                                                          Click="PersonaFormChanged"
                                                          Margin="0,0,0,4" />
                                            </StackPanel>
                                        </Expander>

                                        <DockPanel Margin="0,18,0,0" LastChildFill="False">
                                            <Button x:Name="SavePersonaButton"
                                                    DockPanel.Dock="Right"
                                                    Content="保存角色"
                                                    Click="SavePersonaClick"
                                                    Style="{StaticResource PillPrimaryButton}"
                                                    Width="112" />
                                        </DockPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="工具与能力">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32,24" MaxWidth="680" HorizontalAlignment="Left">
                                <TextBlock Text="工具与能力"
                                           FontSize="{DynamicResource Font.Size.Heading}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"
                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                <TextBlock Text="为自定义模型扩展联网、外部工具与视觉能力。以下能力仅对支持工具调用的自定义（BYOK）模型生效，与 MolaGPT 账号模式互不影响。"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,20"
                                           FontSize="{DynamicResource Font.Size.Small}"
                                           Foreground="{DynamicResource Brush.Text.Muted}" />

                                <TextBlock Text="联网搜索"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"
                                           Foreground="{DynamicResource Brush.Text.Primary}" />

                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="18,16"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="搜索服务"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                                <TextBlock Text="会用于自定义模型的联网搜索"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           Margin="0,3,0,0" />
                                            </StackPanel>
                                            <ComboBox x:Name="WebSearchProviderCombo"
                                                      Grid.Column="1"
                                                      Width="210"
                                                      Style="{StaticResource SettingsComboBox}"
                                                      SelectedValuePath="Tag"
                                                      SelectionChanged="WebSearchProviderCombo_SelectionChanged">
                                                <ComboBoxItem Content="DuckDuckGo（免配置）" Tag="duckduckgo" />
                                                <ComboBoxItem Content="Tavily" Tag="tavily" />
                                                <ComboBoxItem Content="Exa" Tag="exa" />
                                            </ComboBox>
                                        </Grid>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="接入地址" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                <Border Background="{DynamicResource Brush.Bg.Tertiary}" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                    <TextBox x:Name="WebSearchBaseUrlBox"
                                                             Style="{StaticResource InlineTextBox}"
                                                             Text="{Binding WebSearchBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="API Key" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                <Border Background="{DynamicResource Brush.Bg.Tertiary}" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                    <PasswordBox x:Name="WebSearchApiKeyBox"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 Foreground="{DynamicResource Brush.Text.Primary}"
                                                                 FontFamily="{DynamicResource Font.UI}"
                                                                 FontSize="{DynamicResource Font.Size.Body}"
                                                                 PasswordChanged="WebSearchApiKeyBox_PasswordChanged" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,4,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="每次返回结果数" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                <Border Background="{DynamicResource Brush.Bg.Tertiary}" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             Text="{Binding WebSearchMaxResults, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="网页正文截取上限（字符）" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                <Border Background="{DynamicResource Brush.Bg.Tertiary}" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                    <TextBox Style="{StaticResource InlineTextBox}"
                                                             Text="{Binding WebPageMaxCharacters, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Right"
                                                    x:Name="CheckWebSearchButton"
                                                    Style="{StaticResource OutlineButton}"
                                                    Content="测试连接"
                                                    Width="110"
                                                    Click="CheckWebSearchClick" />
                                            <TextBlock x:Name="WebSearchStatusText"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       FontSize="{DynamicResource Font.Size.Small}"
                                                       Foreground="{DynamicResource Brush.Text.Muted}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="MCP 服务器"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,8"
                                           Foreground="{DynamicResource Brush.Text.Primary}" />

                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="18,16"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="已连接的服务器"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                                <TextBlock Text="通过 Model Context Protocol 接入外部工具"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           Margin="0,3,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource OutlineButton}"
                                                    Content="添加服务器"
                                                    Width="120"
                                                    VerticalAlignment="Center"
                                                    Click="AddMcpServerClick" />
                                        </Grid>

                                        <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                BorderThickness="1"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                Padding="6">
                                            <Grid>
                                                <TextBlock x:Name="McpEmptyHint"
                                                           Text="尚未添加任何 MCP 服务器"
                                                           Margin="10,18"
                                                           HorizontalAlignment="Center"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                                <ItemsControl x:Name="McpServersList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Padding="12,9"
                                                                    Margin="0,0,0,4">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Ellipse Grid.Column="0"
                                                                             Width="8" Height="8"
                                                                             Margin="0,0,10,0"
                                                                             VerticalAlignment="Center">
                                                                        <Ellipse.Style>
                                                                            <Style TargetType="Ellipse">
                                                                                <Setter Property="Fill" Value="{DynamicResource Brush.Text.Muted}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Ellipse.Style>
                                                                    </Ellipse>
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="{DynamicResource Font.Size.Small}"
                                                                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                                                                        <TextBlock Text="{Binding Url}"
                                                                                   FontSize="{DynamicResource Font.Size.XSmall}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                                                   Margin="0,2,0,0" />
                                                                    </StackPanel>
                                                                    <Button Grid.Column="2"
                                                                            Style="{StaticResource InlineActionButton}"
                                                                            Margin="4,0,0,0"
                                                                            ToolTip="编辑"
                                                                            Tag="{Binding}"
                                                                            Click="EditMcpServerClick">
                                                                        <TextBlock Text="&#xE70F;" FontFamily="{DynamicResource Font.Icon}" FontSize="13" />
                                                                    </Button>
                                                                    <Button Grid.Column="3"
                                                                            Style="{StaticResource InlineActionButton}"
                                                                            Margin="2,0,0,0"
                                                                            ToolTip="删除"
                                                                            Tag="{Binding}"
                                                                            Click="DeleteMcpServerClick">
                                                                        <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource Font.Icon}" FontSize="13" />
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="仅支持 HTTP (Streamable HTTP) 类型。其工具会自动提供给支持工具调用的自定义模型使用。"
                                                   TextWrapping="Wrap"
                                                   Margin="0,10,0,0"
                                                   FontSize="{DynamicResource Font.Size.Small}"
                                                   Foreground="{DynamicResource Brush.Text.Muted}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="外挂视觉"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,8"
                                           Foreground="{DynamicResource Brush.Text.Primary}" />

                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="18,16"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="图片识别工具"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                                <TextBlock Text="开启后，纯文本输入模型可调用该工具来识别用户发送的图片"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           Margin="0,3,0,0" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      x:Name="VisionEnabledToggle"
                                                      IsChecked="{Binding VisionProxyEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0,0,0" />
                                        </Grid>

                                        <StackPanel x:Name="VisionConfigPanel"
                                                    Margin="0,16,0,0"
                                                    IsEnabled="{Binding IsChecked, ElementName=VisionEnabledToggle}">
                                            <TextBlock Text="视觉模型"
                                                       FontSize="{DynamicResource Font.Size.Small}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       Margin="0,0,0,8" />
                                            <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="12,4">
                                                <ComboBox x:Name="VisionExistingModelCombo"
                                                          Style="{StaticResource SettingsComboBox}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0,6"
                                                          DisplayMemberPath="Label"
                                                          SelectionChanged="VisionExistingModelCombo_SelectionChanged" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="图像生成"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,8"
                                           Foreground="{DynamicResource Brush.Text.Primary}" />

                                <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="18,16"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="BYOK 图像生成"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                                <TextBlock Text="使用独立的图像服务出图，与对话模型分开配置、互不影响"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           Margin="0,3,0,0" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      x:Name="ImageGenerationEnabledToggle"
                                                      IsChecked="{Binding ImageGenerationEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0,0,0" />
                                        </Grid>

                                        <StackPanel Margin="0,16,0,0"
                                                     IsEnabled="{Binding IsChecked, ElementName=ImageGenerationEnabledToggle}">
                                            <TextBlock Text="图像服务" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                            <Border Background="{DynamicResource Brush.Bg.Tertiary}" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8" Margin="0,0,0,12">
                                                <ComboBox x:Name="ImageGenerationModelCombo"
                                                          Style="{StaticResource SettingsComboBox}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0,6"
                                                          DisplayMemberPath="Label"
                                                          SelectionChanged="ImageGenerationModelCombo_SelectionChanged" />
                                            </Border>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="160" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="说明" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                    <TextBlock Text="在「模型服务」中添加图像服务后，即可在此选择。"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                                               FontSize="{DynamicResource Font.Size.Small}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="尺寸" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                        <TextBox Style="{StaticResource InlineTextBox}"
                                                                 Text="{Binding ImageGenerationSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="风格" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}" CornerRadius="{DynamicResource Radius.Sm}" Padding="12,8">
                                                        <TextBox Style="{StaticResource InlineTextBox}"
                                                                 Text="{Binding ImageGenerationStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                                    <CheckBox Content="作为工具加入对话"
                                                              IsChecked="{Binding ImageGenerationAsTool, Mode=TwoWay}"
                                                              Foreground="{DynamicResource Brush.Text.Primary}" />
                                                </StackPanel>
                                            </Grid>

                                            <DockPanel LastChildFill="True">
                                                <Button DockPanel.Dock="Right"
                                                        x:Name="CheckImageGenerationButton"
                                                        Style="{StaticResource OutlineButton}"
                                                        Content="测试连接"
                                                        Width="110"
                                                        Click="CheckImageGenerationClick" />
                                                <TextBlock x:Name="ImageGenerationStatusText"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           FontSize="{DynamicResource Font.Size.Small}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                            </DockPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource Brush.Primary.Blockquote}"
                                        BorderBrush="{DynamicResource Brush.Primary.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="14,12">
                                    <StackPanel>
                                        <TextBlock Text="内置工具"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   Margin="0,0,0,8" />
                                        <WrapPanel>
                                            <Border Background="{DynamicResource Brush.Bg.Elevated}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="{DynamicResource Radius.Sm}" Padding="10,5" Margin="0,0,8,8">
                                                <TextBlock Text="联网搜索" FontSize="{DynamicResource Font.Size.Small}" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                            </Border>
                                            <Border Background="{DynamicResource Brush.Bg.Elevated}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="{DynamicResource Radius.Sm}" Padding="10,5" Margin="0,0,8,8">
                                                <TextBlock Text="网页阅读" FontSize="{DynamicResource Font.Size.Small}" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                            </Border>
                                            <Border Background="{DynamicResource Brush.Bg.Elevated}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="{DynamicResource Radius.Sm}" Padding="10,5" Margin="0,0,8,8">
                                                <TextBlock Text="外挂视觉" FontSize="{DynamicResource Font.Size.Small}" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                            </Border>
                                            <Border Background="{DynamicResource Brush.Bg.Elevated}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="{DynamicResource Radius.Sm}" Padding="10,5" Margin="0,0,8,8">
                                                <TextBlock Text="图像生成" FontSize="{DynamicResource Font.Size.Small}" Foreground="{DynamicResource Brush.Text.Secondary}" />
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Tab: 外观与主题 ===== -->
                    <TabItem Header="外观与主题">
                        <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
                            <TextBlock Text="主题"
                                       FontSize="{DynamicResource Font.Size.Heading}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"
                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="ThemeSystem" Content="跟随系统" GroupName="theme" Margin="0,0,16,0"
                                             Foreground="{DynamicResource Brush.Text.Primary}"
                                             IsChecked="{Binding ThemeMode, Converter={StaticResource EnumEq}, ConverterParameter=System}" />
                                <RadioButton x:Name="ThemeLight" Content="浅色" GroupName="theme" Margin="0,0,16,0"
                                             Foreground="{DynamicResource Brush.Text.Primary}"
                                             IsChecked="{Binding ThemeMode, Converter={StaticResource EnumEq}, ConverterParameter=Light}" />
                                <RadioButton x:Name="ThemeDark" Content="深色" GroupName="theme"
                                             Foreground="{DynamicResource Brush.Text.Primary}"
                                             IsChecked="{Binding ThemeMode, Converter={StaticResource EnumEq}, ConverterParameter=Dark}" />
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <!-- ===== Tab: 输入与通知 ===== -->
                    <TabItem Header="输入与通知">
                        <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
                            <TextBlock Text="Enter 键行为"
                                       FontSize="{DynamicResource Font.Size.Heading}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"
                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                            <CheckBox Content="按 Enter 直接发送消息"
                                      Foreground="{DynamicResource Brush.Text.Primary}"
                                      IsChecked="{Binding EnterToSend}" />
                            <TextBlock Text="关闭时 Enter 换行，Ctrl+Enter 发送；开启时 Shift+Enter 仍可换行。"
                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       FontSize="{DynamicResource Font.Size.Small}" />

                            <TextBlock Text="通知和提醒"
                                       FontSize="{DynamicResource Font.Size.Heading}"
                                       FontWeight="SemiBold"
                                       Margin="0,24,0,12"
                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                            <CheckBox Content="后台回答完成时通知"
                                      Foreground="{DynamicResource Brush.Text.Primary}"
                                      IsChecked="{Binding EnableCompletionNotification}" />
                            <TextBlock Text="开启后，若窗口最小化或切换到其它对话，回答完成时系统会弹出通知。"
                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       FontSize="{DynamicResource Font.Size.Small}" />

                        </StackPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
