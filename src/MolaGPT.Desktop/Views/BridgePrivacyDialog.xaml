<Window x:Class="MolaGPT.Desktop.Views.BridgePrivacyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="隐私说明"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="{DynamicResource Font.Cjk}"
        FontSize="{DynamicResource Font.Size.Body}"
        Foreground="{DynamicResource Brush.Text.Primary}">

    <Grid Margin="20">
        <Border Style="{StaticResource ModalWindowGlow}" />
        <Border Style="{StaticResource ModalWindowSurface}" Padding="0">
            <StackPanel>
                <!-- Header (draggable) -->
                <Border Padding="22,16"
                        BorderBrush="{DynamicResource Brush.Divider}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="HeaderMouseLeftButtonDown">
                    <TextBlock Text="启用远程桥接 · 隐私说明"
                               FontSize="{DynamicResource Font.Size.Title}"
                               FontWeight="Bold" />
                </Border>

                <StackPanel Margin="24,18,24,20">
                    <TextBlock TextWrapping="Wrap"
                               LineHeight="23"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               Text="启用后，MolaGPT 会把本机 Agent 会话（Claude Code / Codex）的状态、对话内容、思考、工具调用与结果，经云端同步到登录同一账号的 MolaGPT App 上以供远程查看与控制。" />

                    <TextBlock TextWrapping="Wrap"
                               Margin="0,14,0,0"
                               LineHeight="22"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               Text="· 数据仅同账号设备可读；&#x0a;· 仅在桥接开启期间同步，关闭后桌面立即标记离线并停止上报；&#x0a;· 会话内容会暂存在中转服务器以支持断线重放，请勿在远程会话中处理高度敏感信息。" />

                    <TextBlock TextWrapping="Wrap"
                               Margin="0,14,0,0"
                               FontSize="{DynamicResource Font.Size.Small}"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               Text="默认关闭。可以随时在「设置 → 本地 Agent → Bridge」中停用。" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                        <Button Style="{StaticResource OutlineButton}"
                                Padding="16,8"
                                Content="取消"
                                Click="CancelClick" />
                        <Button Style="{StaticResource PillPrimaryButton}"
                                Padding="16,8"
                                Margin="10,0,0,0"
                                Content="我已知晓，启用"
                                Click="ConfirmClick" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
