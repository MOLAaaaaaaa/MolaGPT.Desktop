<UserControl x:Class="MolaGPT.Desktop.Views.ImageGenerationWorkbenchWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg.Primary}"
             FontFamily="{DynamicResource Font.Cjk}"
             FontSize="{DynamicResource Font.Size.Body}"
             Foreground="{DynamicResource Brush.Text.Primary}">

    <UserControl.Resources>
        <Style x:Key="WorkbenchSegmentButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Small}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource Radius.Sm}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkbenchChipButton" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Brush.Bg.Elevated}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Md}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Brush.Primary.Border}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Primary.Hover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayIconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Icon}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource Radius.Sm}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#55FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundComposerButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Bg.Secondary}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Icon}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Md}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.Bg.Tertiary}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CurrentTaskTemplate">
            <StackPanel Margin="0,0,0,26"
                        MaxWidth="760"
                        HorizontalAlignment="Stretch">
                <Border HorizontalAlignment="Right"
                        MaxWidth="520"
                        Background="{DynamicResource Brush.Primary.Tint}"
                        BorderBrush="{DynamicResource Brush.Primary.Border}"
                        BorderThickness="1"
                        CornerRadius="12,2,12,12"
                        Padding="12,10"
                        Margin="120,0,0,10"
                        Visibility="{Binding PromptBubbleVisibility}">
                    <StackPanel>
                        <TextBlock Text="{Binding PromptHeader}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Primary}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding Prompt}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="32" Height="32"
                            Margin="0,0,12,0"
                            Visibility="{Binding AvatarVisibility}"
                            Background="{DynamicResource Brush.Primary.Blockquote}"
                            BorderBrush="{DynamicResource Brush.Primary.Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Radius.Md}">
                        <TextBlock Text="&#xE91B;"
                                   FontFamily="{DynamicResource Font.Icon}"
                                   FontSize="13"
                                   Foreground="{DynamicResource Brush.Primary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <Border Grid.Column="1"
                            MaxWidth="640"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource Brush.Bg.Elevated}"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Radius.Md}"
                            Padding="14">
                        <StackPanel>
                            <DockPanel LastChildFill="True" Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="7,2"
                                            Margin="0,0,6,0">
                                        <TextBlock Text="{Binding ImageMeta}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    </Border>
                                    <TextBlock Text="{Binding CreatedAtText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Border Background="{DynamicResource Brush.Primary.Soft}"
                                            BorderBrush="{DynamicResource Brush.Primary.Border}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="8,2"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="{Binding ModeLabel}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Primary}" />
                                    </Border>
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            Padding="7,2"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding ModelLabelVisibility}">
                                        <TextBlock Text="{Binding ModelLabel}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="170" />
                                    </Border>
                                    <TextBlock Text="{Binding TaskTitle}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Primary}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="170" />
                                </StackPanel>
                            </DockPanel>

                            <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource Radius.Sm}"
                                    Padding="8"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding SourceStripVisibility}">
                                <DockPanel LastChildFill="True">
                                    <Border DockPanel.Dock="Left"
                                            Width="44"
                                            Height="44"
                                            Background="{DynamicResource Brush.Bg.Tertiary}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Radius.Sm}"
                                            ClipToBounds="True"
                                            Margin="0,0,10,0">
                                        <Image Source="{Binding SourceThumbnail}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="引用上文图片继续编辑"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                                        <TextBlock Text="{Binding SourceTitle}"
                                                   Margin="0,3,0,0"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource Radius.Sm}"
                                    Padding="10,8"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding TaskPromptVisibility}">
                                <StackPanel>
                                    <TextBlock Text="生成提示词"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding Prompt}"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                </StackPanel>
                            </Border>

                            <Grid Width="420"
                                  HorizontalAlignment="Left">
                                <Grid Visibility="{Binding ImageVisibility}">
                                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Radius.Md}"
                                            ClipToBounds="True">
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>
                                    <Border x:Name="TaskOverlay"
                                            VerticalAlignment="Bottom"
                                            Opacity="0"
                                            Padding="10,24,10,10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                <GradientStop Color="#99000000" Offset="0" />
                                                <GradientStop Color="#00000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource OverlayIconButton}"
                                                    Content="&#xE71E;"
                                                    ToolTip="预览"
                                                    Click="PreviewResultClick" />
                                            <Button Style="{StaticResource OverlayIconButton}"
                                                    Content="&#xE74E;"
                                                    ToolTip="另存"
                                                    Click="SaveResultClick" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Height="260"
                                        Background="{Binding SkeletonBrush}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        ClipToBounds="True"
                                        Visibility="{Binding PendingVisibility}">
                                    <Grid>
                                        <Border x:Name="PendingGlow"
                                                Width="110"
                                                HorizontalAlignment="Left"
                                                Background="#35FFFFFF">
                                            <Border.RenderTransform>
                                                <TranslateTransform X="-130" />
                                            </Border.RenderTransform>
                                        </Border>
                                        <StackPanel HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="14">
                                            <Border Background="{DynamicResource Brush.Workbench.SkeletonBadge}"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="8,4"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding PendingStatusText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                            </Border>
                                            <TextBlock Text="生成完成后将显示在此处。"
                                                       Margin="2,8,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Brush.Workbench.SkeletonHint}" />
                                        </StackPanel>
                                    </Grid>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Border.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="PendingGlow"
                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                     From="-130"
                                                                     To="420"
                                                                     Duration="0:0:1.8"
                                                                     RepeatBehavior="Forever" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Border MinHeight="150"
                                        Background="{DynamicResource Brush.Bg.Secondary}"
                                        BorderBrush="{DynamicResource Brush.Error}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Padding="14"
                                        Visibility="{Binding ErrorVisibility}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="生成失败"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Error}" />
                                        <TextBlock Text="{Binding ErrorDisplay}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   FontSize="12"
                                                   LineHeight="18"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Background="{DynamicResource Brush.Bg.Secondary}"
                                    BorderBrush="{DynamicResource Brush.Primary.Border}"
                                    BorderThickness="2,0,0,0"
                                    CornerRadius="0,6,6,0"
                                    Padding="10,8"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding FooterVisibility}">
                                <TextBlock Text="{Binding RevisedPromptDisplay}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           LineHeight="18"
                                           Foreground="{DynamicResource Brush.Text.Secondary}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="StackPanel.MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="TaskOverlay"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="StackPanel.MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="TaskOverlay"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="GalleryCardTemplate">
            <Border Width="196"
                    Margin="0,0,14,14"
                    Background="{DynamicResource Brush.Bg.Elevated}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.Md}"
                    ClipToBounds="True">
                <StackPanel>
                    <Grid Height="142">
                        <Border Background="{DynamicResource Brush.Bg.Tertiary}">
                            <Image Source="{Binding Thumbnail}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <Border x:Name="GalleryOverlay"
                                VerticalAlignment="Bottom"
                                Opacity="0"
                                Padding="8,20,8,8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#99000000" Offset="0" />
                                    <GradientStop Color="#00000000" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource OverlayIconButton}"
                                        Width="30" Height="30"
                                        Content="&#xE71E;"
                                        ToolTip="预览"
                                        Click="PreviewResultClick" />
                                <Button Style="{StaticResource OverlayIconButton}"
                                        Width="30" Height="30"
                                        Content="&#xE74E;"
                                        ToolTip="另存"
                                        Click="SaveResultClick" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Padding="10,9">
                        <StackPanel>
                            <TextBlock Text="{Binding Prompt}"
                                       MaxHeight="34"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="12"
                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                            <TextBlock Text="{Binding CreatedAtText}"
                                       Margin="0,5,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource Brush.Text.Muted}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Border.MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="GalleryOverlay"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Border.MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="GalleryOverlay"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

                <Grid Background="{DynamicResource Brush.Bg.Primary}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="288" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource Brush.Bg.Secondary}"
                            BorderBrush="{DynamicResource Brush.Divider}"
                            BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,14">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14"
                                           LastChildFill="False">
                                    <Button DockPanel.Dock="Right"
                                            Style="{StaticResource OutlineButton}"
                                            Padding="9,5"
                                            Click="OpenSettingsClick"
                                            ToolTip="在设置中管理图像服务">
                                        <TextBlock Text="模型服务设置" FontSize="12" />
                                    </Button>
                                    <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                        <TextBlock Text="&#xE713;"
                                                   Style="{StaticResource InlineIconTextBlock.Small}"
                                                   Foreground="{DynamicResource Brush.Primary}"
                                                   FontSize="13"
                                                   Margin="0,0,7,0" />
                                        <TextBlock Text="生成参数"
                                                   Style="{StaticResource InlineTextBlock}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Text="画幅比例"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           Margin="0,0,0,6" />
                                <WrapPanel x:Name="RatioChipPanel" Margin="0,0,0,8">
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="1:1" Tag="1024x1024" Click="RatioChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="16:9" Tag="1792x1024" Click="RatioChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="9:16" Tag="1024x1792" Click="RatioChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="4:3" Tag="1536x1024" Click="RatioChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="3:4" Tag="1024x1536" Click="RatioChipClick" />
                                </WrapPanel>

                                <TextBlock Text="尺寸"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           Margin="0,0,0,6" />
                                <ComboBox x:Name="SizePresetCombo"
                                          Style="{StaticResource SettingsComboBox}"
                                          SelectedValuePath="Tag"
                                          SelectionChanged="SizePresetCombo_SelectionChanged"
                                          Margin="0,0,0,8">
                                    <ComboBoxItem Content="1024×1024 · 1:1" Tag="1024x1024" />
                                    <ComboBoxItem Content="1536×1024 · 横图" Tag="1536x1024" />
                                    <ComboBoxItem Content="1024×1536 · 竖图" Tag="1024x1536" />
                                    <ComboBoxItem Content="1792×1024 · 宽屏" Tag="1792x1024" />
                                    <ComboBoxItem Content="1024×1792 · 长图" Tag="1024x1792" />
                                    <ComboBoxItem Content="auto" Tag="auto" />
                                </ComboBox>

                                <TextBlock Text="风格（可选）"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           Margin="0,0,0,6" />
                                <WrapPanel x:Name="StyleChipPanel" Margin="0,0,0,8">
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="无" Tag="" Click="StyleChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="vivid" Tag="vivid" Click="StyleChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="自然" Tag="natural" Click="StyleChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="插画" Tag="illustration" Click="StyleChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="写实" Tag="photorealistic" Click="StyleChipClick" />
                                    <Button Style="{StaticResource WorkbenchChipButton}" Content="动漫" Tag="anime" Click="StyleChipClick" />
                                </WrapPanel>
                                <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Padding="10,7"
                                        Margin="0,0,0,16">
                                    <TextBox x:Name="StyleTextBox"
                                             Style="{StaticResource InlineTextBox}"
                                             TextChanged="OptionTextChanged" />
                                </Border>

                                <Border Background="{DynamicResource Brush.Primary.Blockquote}"
                                        BorderBrush="{DynamicResource Brush.Primary.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Padding="11,10">
                                    <TextBlock x:Name="ConfigSummaryText"
                                               TextWrapping="Wrap"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource Brush.Bg.Canvas}"
                                BorderBrush="{DynamicResource Brush.Divider}"
                                BorderThickness="0,0,0,1"
                                Padding="20,10">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource OutlineButton}"
                                            Padding="9,5"
                                            Margin="0,0,8,0"
                                            Click="NewTaskClick">
                                        <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                            <TextBlock Text="&#xE72C;" Style="{StaticResource InlineIconTextBlock.Small}" FontSize="11" Margin="0,0,5,0" />
                                            <TextBlock Text="新任务" Style="{StaticResource InlineTextBlock.Small}" FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource OutlineButton}"
                                            Padding="9,5"
                                            Click="ClearResultsClick">
                                        <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                            <TextBlock Text="&#xE74D;" Style="{StaticResource InlineIconTextBlock.Small}" FontSize="11" Margin="0,0,5,0" />
                                            <TextBlock Text="清空当前" Style="{StaticResource InlineTextBlock.Small}" FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="CurrentTaskTabButton"
                                            Style="{StaticResource WorkbenchSegmentButton}"
                                            Click="CurrentTaskTabClick"
                                            Margin="0,0,4,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="当前任务" />
                                            <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="6,1"
                                                    Margin="8,0,0,0">
                                                <TextBlock x:Name="CurrentCountText"
                                                           Text="0"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                            </Border>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="GalleryTabButton"
                                            Style="{StaticResource WorkbenchSegmentButton}"
                                            Click="GalleryTabClick">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="画廊" />
                                            <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="6,1"
                                                    Margin="8,0,0,0">
                                                <TextBlock x:Name="GalleryCountText"
                                                           Text="0"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                            </Border>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1" Background="{DynamicResource Brush.Bg.Canvas}">
                            <Grid x:Name="CurrentPane">
                                <TextBlock x:Name="EmptyResultsText"
                                           Text="生成的图片将显示在此处"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                <ScrollViewer x:Name="ResultsScroll" VerticalScrollBarVisibility="Auto" Padding="20,18">
                                    <ItemsControl x:Name="ResultsItems"
                                                  ItemTemplate="{StaticResource CurrentTaskTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <Grid x:Name="GalleryPane" Visibility="Collapsed">
                                <TextBlock x:Name="EmptyGalleryText"
                                           Text="图像工作台的全部作品都会汇集于此"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,18">
                                    <ItemsControl x:Name="GalleryItems"
                                                  ItemTemplate="{StaticResource GalleryCardTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{DynamicResource Brush.Bg.Primary}"
                                Padding="40,0,40,24">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border CornerRadius="{DynamicResource Radius.Xl}"
                                        ClipToBounds="True">
                                    <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                        BorderBrush="{DynamicResource Brush.Border.Strong}"
                                        BorderThickness="1.5"
                                        CornerRadius="{DynamicResource Radius.Xl}"
                                        Padding="14,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Margin="0,0,0,6">
                                            <Border Background="{DynamicResource Brush.Primary.Soft}"
                                                    BorderBrush="{DynamicResource Brush.Primary.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                    Padding="9,4">
                                                <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                                    <TextBlock Text="&#xE91B;"
                                                               Style="{StaticResource InlineIconTextBlock.Small}"
                                                               FontSize="12"
                                                               Margin="0,0,6,0"
                                                               Foreground="{DynamicResource Brush.Primary}" />
                                                    <TextBlock x:Name="ModeBadgeText"
                                                               Text="图像生成"
                                                               Style="{StaticResource InlineTextBlock.Small}"
                                                               FontSize="{DynamicResource Font.Size.Small}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.Primary}" />
                                                </StackPanel>
                                            </Border>

                                            <StackPanel x:Name="EditModeTogglePanel"
                                                        Orientation="Horizontal"
                                                        Visibility="Collapsed"
                                                        VerticalAlignment="Center"
                                                        Margin="10,0,0,0">
                                                <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Padding="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button x:Name="EditRefOnButton"
                                                                Style="{StaticResource WorkbenchSegmentButton}"
                                                                Tag="reference"
                                                                Content="参考上图"
                                                                ToolTip="以最近一张图片为输入进行编辑"
                                                                Click="EditRefModeClick" />
                                                        <Button x:Name="EditRefOffButton"
                                                                Style="{StaticResource WorkbenchSegmentButton}"
                                                                Tag="fresh"
                                                                Content="直接生成"
                                                                ToolTip="不参考上文，直接生成新图"
                                                                Click="EditRefModeClick" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBox Grid.Row="1"
                                                 x:Name="PromptBox"
                                                 Style="{StaticResource ComposerTextBox}"
                                                 MinHeight="52"
                                                 MaxHeight="120"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 TextChanged="PromptBox_TextChanged" />

                                        <DockPanel Grid.Row="2" Margin="0,6,0,0" LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="Enter 发送 · Shift+Enter 换行"
                                                       VerticalAlignment="Center"
                                                       FontSize="{DynamicResource Font.Size.XSmall}"
                                                       Foreground="{DynamicResource Brush.Text.Muted}" />
                                            <Button DockPanel.Dock="Right"
                                                    x:Name="GenerateButton"
                                                    Style="{StaticResource SendButton}"
                                                    ToolTip="生成"
                                                    Click="GenerateClick">
                                                <TextBlock x:Name="GenerateButtonIcon"
                                                           Text="&#xE724;"
                                                           FontFamily="{DynamicResource Font.Icon}" />
                                            </Button>
                                        </DockPanel>
                                    </Grid>
                                    </Border>
                                </Border>

                                <StackPanel Grid.Row="1"
                                            Orientation="Horizontal"
                                            Margin="0,8,0,0">
                                    <Ellipse x:Name="StatusDot"
                                             Width="7"
                                             Height="7"
                                             Fill="{DynamicResource Brush.Success}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,7,0" />
                                    <TextBlock x:Name="StatusText"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               FontSize="{DynamicResource Font.Size.Small}"
                                               Foreground="{DynamicResource Brush.Text.Muted}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
    </DockPanel>
</UserControl>
