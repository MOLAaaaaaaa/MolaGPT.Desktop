<Window x:Class="MolaGPT.Desktop.Views.ImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Width="920"
        Height="680"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Cursor="Hand"
        MouseDown="OnRootMouseDown"
        KeyDown="OnRootKeyDown"
        Focusable="True">
    <Window.Resources>
        <Style x:Key="PreviewToolButton" TargetType="Button">
            <Setter Property="Foreground" Value="#E5111827" />
            <Setter Property="Background" Value="#F2FFFFFF" />
            <Setter Property="BorderBrush" Value="#22000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFFFFFFF" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#33BE727F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFF1E7E9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Border Background="#F8FFFFFF"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="8" Opacity="0.28" />
            </Border.Effect>
        </Border>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Image x:Name="PreviewImage"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="Uniform"
                   StretchDirection="DownOnly"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Border Grid.Row="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    MouseDown="OnToolbarMouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="CopyButton"
                            Content="复制"
                            Style="{StaticResource PreviewToolButton}"
                            Click="OnCopyClick" />
                    <Button x:Name="SaveButton"
                            Content="保存"
                            Style="{StaticResource PreviewToolButton}"
                            Click="OnSaveClick" />
                    <Button Content="✕"
                            Style="{StaticResource PreviewToolButton}"
                            Click="OnCloseClick" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="#11000000"
                    CornerRadius="4"
                    Padding="10,5"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0"
                    MaxWidth="780">
                <TextBlock x:Name="CaptionText"
                           Foreground="#CC111827"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Grid>
</Window>
