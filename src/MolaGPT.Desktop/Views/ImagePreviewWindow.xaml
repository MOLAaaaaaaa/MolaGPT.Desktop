<Window x:Class="MolaGPT.Desktop.Views.ImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Width="920"
        Height="680"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Cursor="Hand"
        MouseDown="OnRootMouseDown"
        KeyDown="OnRootKeyDown"
        Focusable="True">
    <Grid Margin="18">
        <Border Background="#F8FFFFFF"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="8" Opacity="0.28" />
            </Border.Effect>
        </Border>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Image x:Name="PreviewImage"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="Uniform"
                   StretchDirection="DownOnly"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Border Grid.Row="1"
                    Background="#11000000"
                    CornerRadius="4"
                    Padding="10,5"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0"
                    MaxWidth="780">
                <TextBlock x:Name="CaptionText"
                           Foreground="#CC111827"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Grid>
</Window>
