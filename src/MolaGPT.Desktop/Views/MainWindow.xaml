<Window x:Class="MolaGPT.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MolaGPT.ViewModels;assembly=MolaGPT.ViewModels"
        xmlns:views="clr-namespace:MolaGPT.Desktop.Views"
        xmlns:chat="clr-namespace:MolaGPT.Core.Chat;assembly=MolaGPT.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Icon="/Assets/app-logo.png"
        Height="820" Width="1280"
        MinHeight="540" MinWidth="900"
        Background="{DynamicResource Brush.Bg.Canvas}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.UI}"
        FontSize="{DynamicResource Font.Size.Body}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="MainWindow_StateChanged"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        mc:Ignorable="d">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <!-- Main desktop layout: two floating cards (sidebar + main) on a soft
         canvas with 16px padding/gap.
         SidebarColumn.Width is animated by MainWindow.xaml.cs in response
         to MainViewModel.SidebarCollapsed (no XAML binding because Grid
         columns aren't FrameworkElements and can't carry storyboards). -->
    <Border x:Name="RootBorder" Background="{DynamicResource Brush.Bg.Canvas}">
    <DockPanel>

        <!-- ===== Self-drawn title bar (WindowChrome) =====
             Replaces the default OS title bar: brand on the left, the mode
             switcher centered, self-drawn min/max/close on the right. The 46px
             caption region is draggable; interactive controls opt back in with
             shell:WindowChrome.IsHitTestVisibleInChrome="True". -->
        <Grid DockPanel.Dock="Top" Height="46" Background="{DynamicResource Brush.Bg.Canvas}">
            <Grid.Resources>
                <!-- Horizontal mode segment: transparent, rose-soft when active. -->
                <Style x:Key="ModeSegButton" TargetType="Button">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Padding" Value="12,4" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="FontFamily" Value="{DynamicResource Font.UI}" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="7"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <!-- Window caption button (minimize / maximize). -->
                <Style x:Key="CaptionButton" TargetType="Button">
                    <Setter Property="Width" Value="46" />
                    <Setter Property="Height" Value="46" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="FontFamily" Value="{DynamicResource Font.Icon}" />
                    <Setter Property="FontSize" Value="10" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Brush.Bg.HoverOverlay}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <!-- Close button: red hover (Windows convention). -->
                <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E81123" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: brand (drag region; heart opts back in to clicks) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <Border Width="24" Height="24" CornerRadius="7" ClipToBounds="True">
                    <Image Source="/Assets/app-logo.png"
                           Stretch="UniformToFill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
                <Button Style="{StaticResource HeaderIconButton}"
                        Margin="4,0,0,0"
                        Visibility="Collapsed"
                        ToolTip="支持我"
                        FontFamily="Segoe UI Emoji"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="❤" Foreground="{DynamicResource Brush.Primary}" FontSize="13" />
                </Button>
            </StackPanel>

            <!-- Center: mode switcher — MolaGPT Chat (web) vs MolaGPT Work (local
                 agent). The BYOK-vs-account wallet split is NOT shown here; it's
                 chosen in the model selector. Work is active for both Work and BYOK. -->
            <Border Grid.Column="1"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Brush.Bg.Tertiary}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.Md}"
                    Padding="3"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding SwitchModeCommand}" CommandParameter="chat"
                            ToolTip="MolaGPT 网页版对话 · 云端同步。">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModeSegButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Chat.CurrentMode}" Value="{x:Static chat:AppMode.Chat}">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Primary.Hover}" />
                                        <Setter Property="Background" Value="{DynamicResource Brush.Primary.Soft}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Primary.Border}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="MolaGPT Chat" FontSize="12" HorizontalAlignment="Center" />
                            <TextBlock Text="网页版对话" FontSize="9" Opacity="0.7" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Margin="2,0,0,0" Command="{Binding SwitchModeCommand}" CommandParameter="work"
                            ToolTip="MolaGPT Work · 工具 / Agent。账号额度或自定义 API Key.">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModeSegButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Chat.CurrentMode}" Value="{x:Static chat:AppMode.Work}">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Primary.Hover}" />
                                        <Setter Property="Background" Value="{DynamicResource Brush.Primary.Soft}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Primary.Border}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Chat.CurrentMode}" Value="{x:Static chat:AppMode.Byok}">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Primary.Hover}" />
                                        <Setter Property="Background" Value="{DynamicResource Brush.Primary.Soft}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Primary.Border}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="MolaGPT Work" FontSize="12" HorizontalAlignment="Center" />
                            <TextBlock Text="本地对话" FontSize="9" Opacity="0.7" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Right: global actions (moved up from the content header) + window controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource HeaderIconButton}" Command="{Binding OpenAgentStatusCommand}" ToolTip="Agent 状态（Claude Code / Codex）">
                        <TextBlock Text="&#xE756;" FontFamily="{DynamicResource Font.Icon}" />
                    </Button>
                    <Button Style="{StaticResource HeaderIconButton}" Command="{Binding OpenSettingsCommand}" ToolTip="设置">
                        <TextBlock Text="&#xE713;" FontFamily="{DynamicResource Font.Icon}" />
                    </Button>
                    <Button Style="{StaticResource HeaderIconButton}" Command="{Binding OpenAboutCommand}" ToolTip="关于 MolaGPT">
                        <TextBlock Text="&#xE946;" FontFamily="{DynamicResource Font.Icon}" />
                    </Button>
                    <Button Style="{StaticResource HeaderIconButton}" Command="{Binding ToggleThemeCommand}" ToolTip="主题切换">
                        <TextBlock Text="&#xE793;" FontFamily="{DynamicResource Font.Icon}" />
                    </Button>
                    <Button Style="{StaticResource HeaderIconButton}" Command="{Binding OpenLoginCommand}" ToolTip="登录 / 账户">
                        <TextBlock Text="&#xE77B;" FontFamily="{DynamicResource Font.Icon}" />
                    </Button>
                </StackPanel>
                <Button Style="{StaticResource CaptionButton}" Click="MinimizeWindow_Click" ToolTip="最小化">
                    <TextBlock Text="&#xE921;" />
                </Button>
                <Button x:Name="MaximizeRestoreButton" Style="{StaticResource CaptionButton}" Click="MaximizeRestoreWindow_Click" ToolTip="最大化">
                    <TextBlock x:Name="MaximizeRestoreGlyph" Text="&#xE922;" />
                </Button>
                <Button Style="{StaticResource CaptionCloseButton}" Click="CloseWindow_Click" ToolTip="关闭">
                    <TextBlock Text="&#xE8BB;" />
                </Button>
            </StackPanel>
        </Grid>

    <Grid Margin="16,6,16,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280" />
            <ColumnDefinition x:Name="GapColumn" Width="16" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="ArtifactGapColumn" Width="0" />
            <ColumnDefinition x:Name="ArtifactColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <!-- ========================================================
             SIDEBAR — floating card.
             Visibility flips to Collapsed when fully collapsed so the
             sidebar's content doesn't paint into a 0px-wide column.
             ======================================================== -->
        <Border x:Name="SidebarCard"
                Grid.Column="0"
                Style="{StaticResource FloatingCard}"
                Background="{DynamicResource Brush.Bg.Secondary}"
                ClipToBounds="True">
            <DockPanel LastChildFill="True">
                <!-- Sidebar header -->
                <DockPanel DockPanel.Dock="Top" Margin="20,20,16,12" LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource HeaderIconButton}"
                            Width="32" Height="32"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip="收起侧边栏">
                        <TextBlock Text="&#xE76B;" FontFamily="{DynamicResource Font.Icon}" FontSize="12" />
                    </Button>
                    <TextBlock Text="对话历史"
                               FontSize="{DynamicResource Font.Size.Title}"
                               FontWeight="ExtraBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Primary}" />
                </DockPanel>

                <!-- New chat (pill) -->
                <Button DockPanel.Dock="Top"
                        Margin="20,4,16,8"
                        Style="{StaticResource PillPrimaryButton}"
                        Command="{Binding NewConversationCommand}">
                    <StackPanel Style="{StaticResource InlineIconTextPanel}" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE710;" Style="{StaticResource InlineIconTextBlock}" FontSize="13" Margin="0,0,8,0" />
                        <TextBlock Text="新建对话" Style="{StaticResource InlineTextBlock}" />
                    </StackPanel>
                </Button>

                <!-- Mode switcher moved to the custom title bar (top of window). -->


                <!-- Search box -->
                <Border DockPanel.Dock="Top"
                        Margin="20,4,16,8"
                        Padding="14,8"
                        Background="{DynamicResource Brush.Bg.Tertiary}"
                        CornerRadius="{DynamicResource Radius.Sm}">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="&#xE721;"
                                   FontFamily="{DynamicResource Font.Icon}"
                                   FontSize="13"
                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Style="{StaticResource InlineTextBox}"
                                 Text="{Binding ConversationList.SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </Border>

                <!-- Multi-selection toolbar -->
                <Border DockPanel.Dock="Top"
                        Margin="20,0,16,6"
                        Padding="10,7"
                        Background="{DynamicResource Brush.Primary.Tint}"
                        BorderBrush="{DynamicResource Brush.Primary.Border}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius.Sm}"
                        Visibility="{Binding ConversationList.HasSelectedConversations, Converter={x:Static views:BoolToVisibility.Instance}}">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource HeaderIconButton}"
                                Width="28" Height="28"
                                Command="{Binding ConversationList.DeleteSelectedConversationsCommand}"
                                ToolTip="删除已选对话">
                            <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource Font.Icon}" FontSize="13" />
                        </Button>
                        <TextBlock Text="{Binding ConversationList.SelectionSummary}"
                                   VerticalAlignment="Center"
                                   FontSize="{DynamicResource Font.Size.Small}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Primary.Hover}" />
                    </DockPanel>
                </Border>


                <!-- ============================================================
                     Grouped conversation list — BYOK on top, MolaGPT below.
                     Both groups individually collapsible; expansion state
                     persists in SettingsRepository. We use two parallel
                     ListBox instances bound to ByokItems / MolaGptItems
                     rather than a single ListBox + GroupStyle, so the VM
                     project can stay PresentationFramework-free.
                     Keep each ListBox height-bounded so WPF virtualization
                     stays active for large local histories.
                     ============================================================ -->
                <Grid Margin="14,4,12,8">
                    <Grid.Resources>
                        <DataTemplate x:Key="ConversationRowTemplate" DataType="{x:Type vm:ConversationListItem}">
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource HeaderIconButton}"
                                        Width="24" Height="24"
                                        Margin="4,0,0,0"
                                        Command="{Binding DataContext.ConversationList.DeleteConversationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"
                                        ToolTip="删除对话">
                                    <TextBlock Text="&#xE74D;" FontFamily="{DynamicResource Font.Icon}" FontSize="11" />
                                </Button>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding TimeLabel}"
                                           FontSize="{DynamicResource Font.Size.XSmall}"
                                           Opacity="0.65"
                                           VerticalAlignment="Center" />
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Margin="6,0,4,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsGenerating, Converter={x:Static views:BoolToVisibility.Instance}}">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource Brush.Primary}" Margin="0,0,3,0" Opacity="0.6" />
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource Brush.Primary}" Margin="0,0,3,0" Opacity="0.6" />
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource Brush.Primary}" Opacity="0.6" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right"
                                        Margin="6,0,0,0"
                                        Padding="6,0"
                                        Height="20"
                                        MinWidth="32"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource Brush.Bg.Tertiary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Visibility="{Binding IsByok, Converter={x:Static views:BoolToVisibility.Instance}}"
                                        ToolTip="{Binding BadgeLabel}">
                                    <TextBlock Text="{Binding BadgeLabel}"
                                               FontSize="{DynamicResource Font.Size.XSmall}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="80"
                                               VerticalAlignment="Center"
                                               LineHeight="12"
                                               LineStackingStrategy="BlockLineHeight" />
                                </Border>
                                <Border DockPanel.Dock="Right"
                                        Margin="6,0,0,0"
                                        Padding="6,0"
                                        Height="20"
                                        MinWidth="32"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource Brush.Bg.Tertiary}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Visibility="{Binding IsWork, Converter={x:Static views:BoolToVisibility.Instance}}"
                                        ToolTip="MolaGPT Work">
                                    <TextBlock Text="{Binding ModeBadgeLabel}"
                                               FontSize="{DynamicResource Font.Size.XSmall}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               LineHeight="12"
                                               LineStackingStrategy="BlockLineHeight" />
                                </Border>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding IconGlyph}"
                                           FontFamily="{DynamicResource Font.Icon}"
                                           FontSize="13"
                                           Opacity="0.7"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="Medium" />
                            </DockPanel>
                        </DataTemplate>
                    </Grid.Resources>

                    <Grid x:Name="ConversationGroupsHost"
                          MouseEnter="ConversationGroupsHost_MouseEnter"
                          MouseLeave="ConversationGroupsHost_MouseLeave">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="ByokHeaderRow" Height="Auto" />
                            <RowDefinition x:Name="ByokListRow" Height="Auto" />
                            <RowDefinition x:Name="MolaGptHeaderRow" Height="Auto" />
                            <RowDefinition x:Name="MolaGptListRow" Height="*" />
                        </Grid.RowDefinitions>

                        <!-- ===== BYOK group ===== -->
                        <Button Grid.Row="0"
                                Tag="byok"
                                Style="{StaticResource SidebarGroupHeaderButton}"
                                Command="{Binding ConversationList.ToggleByokGroupCommand}"
                                Click="ConversationGroupHeader_Click"
                                Visibility="{Binding ConversationList.HasByokConversations, Converter={x:Static views:BoolToVisibility.Instance}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding ConversationList.ByokGroupChevron}"
                                           Style="{StaticResource InlineIconTextBlock.Small}"
                                           FontSize="9"
                                           Opacity="0.7"
                                           Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1"
                                           Text="BYOK 模型"
                                           Style="{StaticResource InlineTextBlock.Small}"
                                           FontSize="{DynamicResource Font.Size.XSmall}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.Text.Secondary}" />
                                <Border Grid.Column="2"
                                        Background="{DynamicResource Brush.Bg.Primary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6,1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ConversationList.ByokCount}"
                                               Style="{StaticResource InlineTextBlock.Small}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Muted}" />
                                </Border>
                            </Grid>
                        </Button>
                        <ListBox Grid.Row="1"
                                 x:Name="ByokListBox"
                                 ItemsSource="{Binding ConversationList.ByokItems}"
                                 SelectedValue="{Binding ConversationList.SelectedId, Mode=OneWayToSource}"
                                 SelectedValuePath="Id"
                                 SelectionMode="Extended"
                                 SelectionChanged="ConversationListBox_SelectionChanged"
                                 PreviewMouseWheel="ConversationGroupList_PreviewMouseWheel"
                                 ScrollViewer.ScrollChanged="ConversationGroupList_ScrollChanged"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="240"
                                 ItemContainerStyle="{StaticResource ConversationListItemStyle}"
                                 ItemTemplate="{StaticResource ConversationRowTemplate}"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 VirtualizingStackPanel.ScrollUnit="Pixel">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ConversationList.HasByokConversations}" Value="True" />
                                                <Condition Binding="{Binding ConversationList.IsByokGroupExpanded}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                        </ListBox>

                        <!-- ===== MolaGPT group ===== -->
                        <Button Grid.Row="2"
                                Tag="molagpt"
                                Style="{StaticResource SidebarGroupHeaderButton}"
                                Command="{Binding ConversationList.ToggleMolaGptGroupCommand}"
                                Click="ConversationGroupHeader_Click"
                                Visibility="{Binding ConversationList.HasMolaGptConversationItems, Converter={x:Static views:BoolToVisibility.Instance}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding ConversationList.MolaGptGroupChevron}"
                                           Style="{StaticResource InlineIconTextBlock.Small}"
                                           FontSize="9"
                                           Opacity="0.7"
                                           Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1"
                                           Text="MolaGPT 对话"
                                           Style="{StaticResource InlineTextBlock.Small}"
                                           FontSize="{DynamicResource Font.Size.XSmall}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.Text.Secondary}" />
                                <Border Grid.Column="2"
                                        Background="{DynamicResource Brush.Bg.Primary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6,1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ConversationList.MolaGptConversationCount}"
                                               Style="{StaticResource InlineTextBlock.Small}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Muted}" />
                                </Border>
                            </Grid>
                        </Button>
                        <ListBox Grid.Row="3"
                                 x:Name="MolaGptListBox"
                                 ItemsSource="{Binding ConversationList.MolaGptConversationItems}"
                                 SelectedValue="{Binding ConversationList.SelectedId, Mode=OneWayToSource}"
                                 SelectedValuePath="Id"
                                 SelectionMode="Extended"
                                 SelectionChanged="ConversationListBox_SelectionChanged"
                                 PreviewMouseWheel="ConversationGroupList_PreviewMouseWheel"
                                 ScrollViewer.ScrollChanged="ConversationGroupList_ScrollChanged"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource ConversationListItemStyle}"
                                 ItemTemplate="{StaticResource ConversationRowTemplate}"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 VirtualizingStackPanel.ScrollUnit="Pixel">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ConversationList.HasMolaGptConversationItems}" Value="True" />
                                                <Condition Binding="{Binding ConversationList.IsMolaGptGroupExpanded}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                        </ListBox>

                    </Grid>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ========================================================
             MAIN — floating card with floating header & composer
             ======================================================== -->
        <Border x:Name="MainCard"
                Grid.Column="2"
                Background="{DynamicResource Brush.Bg.Primary}"
                CornerRadius="{DynamicResource Radius.Xxl}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Grid x:Name="ChatSurface"
                      Visibility="{Binding IsImageWorkbenchVisible, Converter={x:Static views:BoolToVisibilityInverse.Instance}}">
                <!-- Welcome screen — separate overlay (NOT inside the
                     virtualizing scroller) so its presence/absence doesn't
                     interfere with VirtualizingStackPanel's IScrollInfo
                     contract on the message list. -->
                <ContentControl Visibility="{Binding Chat.IsEmpty, Converter={x:Static views:BoolToVisibility.Instance}}"
                                Margin="40,80,40,180">
                    <views:WelcomeView DataContext="{Binding Chat}" />
                </ContentControl>

                <!-- Messages scroll area.
                     ScrollViewer.CanContentScroll=True is mandatory for
                     VirtualizingStackPanel virtualization to engage; combined
                     with ScrollUnit=Pixel below the wheel still scrolls in
                     pixels (not in whole items). The ItemsControl is the
                     direct child of the ScrollViewer — no wrapper Grid —
                     because virtualization requires the IScrollInfo delegate
                     (the inner VirtualizingStackPanel) to be reachable. -->
                <ScrollViewer x:Name="MessagesScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              Padding="40,64,40,6"
                              Margin="0,0,0,160"
                              SizeChanged="MessagesScroll_SizeChanged"
                              ScrollChanged="MessagesScroll_ScrollChanged"
                              PreviewMouseWheel="MessagesScroll_PreviewMouseWheel"
                              MouseWheel="MessagesScroll_MouseWheel"
                              Visibility="{Binding Chat.IsEmpty, Converter={x:Static views:BoolToVisibilityInverse.Instance}}">
                    <ItemsControl ItemsSource="{Binding Chat.Messages}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,8"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  VirtualizingStackPanel.ScrollUnit="Pixel"
                                  VirtualizingStackPanel.CacheLengthUnit="Pixel"
                                  VirtualizingStackPanel.CacheLength="800,800"
                                  ScrollViewer.CanContentScroll="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:MessageViewModel}">
                                <Grid HorizontalAlignment="Stretch" Margin="0,4">
                                    <views:MessageItemView />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                </Grid>

                <!-- Conversation-load indicator. A large conversation can take
                     a few seconds to render its FlowDocument blocks; without
                     this the window looks frozen on click. A centered pill with
                     a spinning glyph shows progress while Chat.IsConversationLoading.
                     No dimming backdrop (it caused a flash on fast loads); the
                     pill's fade-in keeps brief appearances unobtrusive. Its
                     first paint is forced synchronously before the load freeze
                     (see MainWindow.ConversationListBox_SelectionChanged). -->
                <Border VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Panel.ZIndex="50"
                        Background="{DynamicResource Brush.Bg.Elevated}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="22,13"
                        Visibility="{Binding Chat.IsConversationLoading, Converter={x:Static views:BoolToVisibility.Instance}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="3" Direction="270" Opacity="0.24" Color="#000000" />
                    </Border.Effect>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Chat.IsConversationLoading}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.12" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ConversationLoadingSpinner"
                                   Text="&#xF16A;"
                                   FontFamily="{DynamicResource Font.Icon}"
                                   FontSize="18"
                                   Foreground="{DynamicResource Brush.Primary.Hover}"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5"
                                   Margin="0,0,11,0">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0" />
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Chat.IsConversationLoading}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="SpinStory">
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                            From="0" To="360" Duration="0:0:0.9"
                                                            RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="SpinStory" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="加载对话中…"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Scroll-to-bottom affordance. Fades in when the user
                     scrolls away from the bottom (e.g. reading back while a
                     reply streams) and jumps back to the latest content on
                     click. Collapsed by default; OnMessagesScrollFollowChanged
                     toggles Opacity/HitTest in code-behind. Anchored just
                     above the floating composer. -->
                <Button x:Name="ScrollToBottomButton"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,196"
                        Width="32"
                        Height="32"
                        Opacity="0"
                        IsHitTestVisible="False"
                        Cursor="Hand"
                        ToolTip="滚动到底部"
                        Click="ScrollToBottomButton_Click"
                        Visibility="{Binding Chat.IsEmpty, Converter={x:Static views:BoolToVisibilityInverse.Instance}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="{DynamicResource Brush.Bg.Elevated}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12"
                                                      ShadowDepth="2"
                                                      Direction="270"
                                                      Opacity="0.20"
                                                      Color="#000000" />
                                </Border.Effect>
                                <TextBlock Text="&#xE74B;"
                                           FontFamily="{DynamicResource Font.Icon}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Brush.Bg.Primary}" />
                                    <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource Brush.Text.Secondary}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Floating top header centered above the active page. -->
                <Border VerticalAlignment="Top"
                        Margin="16,16,16,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="16,8">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: optional expand-sidebar pill + app logo + heart.
                             The expand pill only appears when the sidebar is
                             collapsed; clicking it flips MainViewModel.SidebarCollapsed
                             which the code-behind animates. -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource HeaderIconButton}"
                                    Width="32" Height="32"
                                    Margin="0,0,8,0"
                                    Command="{Binding ToggleSidebarCommand}"
                                    ToolTip="展开侧边栏"
                                    Visibility="{Binding SidebarCollapsed, Converter={x:Static views:BoolToVisibility.Instance}}">
                                <TextBlock Text="&#xE700;" FontFamily="{DynamicResource Font.Icon}" FontSize="12" />
                            </Button>
                            <!-- App logo + heart moved to the custom title bar. -->

                        </StackPanel>

                        <!-- Center: model selector pill -->
                        <Button Grid.Column="1"
                                x:Name="ChatModelSelectorButton"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource OutlineButton}"
                                Padding="14,6"
                                Margin="16,0,0,0"
                                Click="OpenModelSelector_Click"
                                ToolTip="选择模型"
                                Visibility="{Binding IsImageWorkbenchVisible, Converter={x:Static views:BoolToVisibilityInverse.Instance}}">
                            <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                <TextBlock Text="&#xE99A;" Style="{StaticResource InlineIconTextBlock}" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Chat.ActiveModelLabel}" Style="{StaticResource InlineTextBlock}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Chat.ActiveModeLabel}"
                                           Style="{StaticResource InlineTextBlock.Small}"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           FontSize="{DynamicResource Font.Size.XSmall}"
                                           Margin="8,0,0,0" />
                                <TextBlock Text="&#xE70D;" Style="{StaticResource InlineIconTextBlock.Small}" FontSize="10" Margin="8,0,0,0" Opacity="0.6" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                x:Name="WorkbenchModelSelectorButton"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource OutlineButton}"
                                Padding="14,6"
                                Margin="16,0,0,0"
                                ToolTip="选择图像模型"
                                Visibility="{Binding IsImageWorkbenchVisible, Converter={x:Static views:BoolToVisibility.Instance}}">
                            <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                <TextBlock Text="&#xE91B;" Style="{StaticResource InlineIconTextBlock}" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock x:Name="WorkbenchModelLabel"
                                           Text="图像模型"
                                           Style="{StaticResource InlineTextBlock}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="260" />
                                <TextBlock Text="&#xE70D;" Style="{StaticResource InlineIconTextBlock.Small}" FontSize="10" Margin="8,0,0,0" Opacity="0.6" />
                            </StackPanel>
                        </Button>

                        <!-- Right: action icons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Quota chip is prewired in MainViewModel and kept out of the
                                 current chrome for now. -->
                            <Button Style="{StaticResource HeaderIconButton}"
                                    Width="Auto"
                                    Padding="8,4"
                                    Margin="0,0,6,0"
                                    Command="{Binding OpenUpdateDownloadCommand}"
                                    ToolTip="{Binding UpdateTooltip}"
                                    Visibility="{Binding UpdateAvailable, Converter={x:Static views:BoolToVisibility.Instance}}">
                                <Border Padding="9,3"
                                        Background="{DynamicResource Brush.Primary.Tint}"
                                        BorderBrush="{DynamicResource Brush.Primary.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}">
                                    <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                        <TextBlock Text="&#xE777;"
                                                   Style="{StaticResource InlineIconTextBlock.Small}"
                                                   FontSize="12"
                                                   Margin="0,0,6,0"
                                                   Foreground="{DynamicResource Brush.Primary}" />
                                        <TextBlock Text="{Binding UpdateChipLabel}"
                                                   Style="{StaticResource InlineTextBlock.Small}"
                                                   FontFamily="{DynamicResource Font.Cjk}"
                                                   FontSize="{DynamicResource Font.Size.XSmall}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Primary}" />
                                        <TextBlock Text="{Binding UpdateChipDetail}"
                                                   Style="{StaticResource InlineTextBlock.Small}"
                                                   FontFamily="{DynamicResource Font.Cjk}"
                                                   FontSize="{DynamicResource Font.Size.XSmall}"
                                                   Margin="5,0,0,0"
                                                   Opacity="0.75"
                                                   Foreground="{DynamicResource Brush.Primary}" />
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Style="{StaticResource HeaderIconButton}"
                                    Width="Auto"
                                    MinWidth="116"
                                    Padding="8,4"
                                    Margin="0,0,6,0"
                                    Command="{Binding SyncCloudCommand}"
                                    ToolTip="{Binding CloudSyncStatusToolTip}"
                                    Visibility="{Binding IsCloudSyncChipVisible, Converter={x:Static views:BoolToVisibility.Instance}}">
                                <Border Padding="8,3"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Bg.Tertiary}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CloudSyncStatusKind}" Value="Syncing">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Primary.Tint}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Primary.Border}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CloudSyncStatusKind}" Value="Success">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Success}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CloudSyncStatusKind}" Value="Error">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Warning}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CloudSyncStatusKind}" Value="Disabled">
                                                    <Setter Property="Opacity" Value="0.62" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Style="{StaticResource InlineIconTextPanel}">
                                        <Ellipse Width="7" Height="7" Margin="0,0,7,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{DynamicResource Brush.Text.Muted}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CloudSyncStatusKind}" Value="Syncing">
                                                            <Setter Property="Fill" Value="{DynamicResource Brush.Primary}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CloudSyncStatusKind}" Value="Success">
                                                            <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CloudSyncStatusKind}" Value="Error">
                                                            <Setter Property="Fill" Value="{DynamicResource Brush.Warning}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="&#xE753;"
                                                   Style="{StaticResource InlineIconTextBlock.Small}"
                                                   FontSize="12"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding CloudSyncStatusText}"
                                                   Style="{StaticResource InlineTextBlock.Small}"
                                                   MaxWidth="150"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontFamily="{DynamicResource Font.Cjk}"
                                                   FontSize="{DynamicResource Font.Size.XSmall}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Style="{StaticResource HeaderIconButton}"
                                    Command="{Binding OpenSystemPromptCommand}"
                                    Visibility="{Binding ConversationSystemPromptVisible, Converter={x:Static views:BoolToVisibility.Instance}}"
                                    ToolTip="会话提示词覆盖">
                                <Grid>
                                    <TextBlock Text="&#xE8A5;" FontFamily="{DynamicResource Font.Icon}" />
                                    <!-- Active indicator: small primary-colored dot in
                                         the top-right corner when this conversation
                                         has a conversation-level prompt override set.
                                         Mirrors the macOS "modified document" cue so
                                         users can see at a glance that the prompt isn't
                                         the persona default. -->
                                    <Ellipse Width="7" Height="7"
                                             Fill="{DynamicResource Brush.Primary}"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Top"
                                             Margin="0,-2,-2,0"
                                             Visibility="{Binding Chat.ConversationSystemPrompt, Converter={x:Static views:NullToInverseVisibility.Instance}}" />
                                </Grid>
                            </Button>
                            <!-- 设置 / 关于 / 主题 / 账户 已移到顶部标题栏 header。 -->
                        </StackPanel>
                    </Grid>
                </Border>

                <Popup x:Name="WorkbenchModelSelectorPopup"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=WorkbenchModelSelectorButton}"
                       HorizontalOffset="0"
                       VerticalOffset="6">
                    <Grid Margin="14">
                        <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Md}"
                                Padding="6"
                                MinWidth="320"
                                MaxHeight="420">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Padding="10,6"
                                        Margin="4,4,4,6">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="&#xE721;"
                                                   DockPanel.Dock="Left"
                                                   FontFamily="{DynamicResource Font.Icon}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center" />
                                        <TextBox x:Name="WorkbenchModelSelectorSearchBox"
                                                 Style="{StaticResource InlineTextBox}"
                                                 ToolTip="搜索图像模型"
                                                 TextChanged="WorkbenchModelSelectorSearchBox_TextChanged" />
                                    </DockPanel>
                                </Border>
                                <ListBox Grid.Row="1"
                                         x:Name="WorkbenchModelSelectorItems"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.CanContentScroll="True"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                                         VirtualizingStackPanel.ScrollUnit="Pixel">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter
                                                            Margin="{TemplateBinding Padding}"
                                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Button Style="{StaticResource HintChip}"
                                                        Margin="4,2"
                                                        Padding="12,6"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Visibility="{Binding ModelVisibility}"
                                                        Click="WorkbenchModelSelectorRow_Click">
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="13"
                                                               FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                                <TextBlock Text="{Binding EmptyText}"
                                                           Margin="12"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           Visibility="{Binding EmptyVisibility}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Popup>

                <Grid x:Name="ChatComposerSurface"
                      Visibility="{Binding IsImageWorkbenchVisible, Converter={x:Static views:BoolToVisibilityInverse.Instance}}">
                <!-- Floating composer -->
                <Border x:Name="ComposerHost"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Margin="40,0,40,24"
                        SizeChanged="ComposerHost_SizeChanged">
                    <views:ComposerView DataContext="{Binding Composer}" />
                </Border>

                <!-- Model selector popup (dynamically populated).
                     Outer Grid Margin=14 keeps spacing around the rounded menu
                     render outside the rounded Border without being clipped
                     by the Popup's HWND boundary — this fixes the visible
                     "square corner" artifact at the popup's bounding box. -->
                <Popup x:Name="ModelSelectorPopup"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=MessagesScroll}"
                       HorizontalOffset="20"
                       VerticalOffset="-8">
                    <Grid Margin="14">
                        <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Md}"
                                Padding="6"
                                MinWidth="280"
                                MaxHeight="420">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Padding="10,6"
                                        Margin="4,4,4,6">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="&#xE721;"
                                                   DockPanel.Dock="Left"
                                                   FontFamily="{DynamicResource Font.Icon}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center" />
                                        <TextBox x:Name="ModelSelectorSearchBox"
                                                 Style="{StaticResource InlineTextBox}"
                                                 ToolTip="搜索模型"
                                                 TextChanged="ModelSelectorSearchBox_TextChanged" />
                                    </DockPanel>
                                </Border>
                                <ListBox Grid.Row="1"
                                         x:Name="ModelSelectorItems"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.CanContentScroll="True"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                                         VirtualizingStackPanel.ScrollUnit="Pixel">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter
                                                            Margin="{TemplateBinding Padding}"
                                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="{Binding HeaderText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           Margin="10,8,6,4"
                                                           Opacity="0.85"
                                                           Visibility="{Binding HeaderVisibility}" />
                                                <Border Margin="8,3,8,7"
                                                        Padding="10,7"
                                                        Background="{DynamicResource Brush.Primary.Tint}"
                                                        BorderBrush="{DynamicResource Brush.Primary.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.Sm}"
                                                        Visibility="{Binding HintVisibility}">
                                                    <TextBlock Text="{Binding HintText}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.Primary.Hover}"
                                                               TextWrapping="Wrap"
                                                               LineHeight="16"
                                                               LineStackingStrategy="BlockLineHeight" />
                                                </Border>
                                                <Button Style="{StaticResource HintChip}"
                                                        Margin="4,2"
                                                        Padding="12,6"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Visibility="{Binding ModelVisibility}"
                                                        Click="ModelSelectorRow_Click">
                                                    <DockPanel LastChildFill="True">
                                                        <StackPanel DockPanel.Dock="Right"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Border Margin="6,0,0,0"
                                                                    Padding="5,1"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Background="{DynamicResource Brush.Bg.Tertiary}"
                                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                                    BorderThickness="1"
                                                                    Visibility="{Binding ThinkingVisibility}">
                                                                <TextBlock Text="推理"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                                            </Border>
                                                            <Border Margin="6,0,0,0"
                                                                    Padding="5,1"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Background="{DynamicResource Brush.Bg.Tertiary}"
                                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                                    BorderThickness="1"
                                                                    Visibility="{Binding ToolsVisibility}">
                                                                <TextBlock Text="工具"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                                            </Border>
                                                            <Border Margin="6,0,0,0"
                                                                    Padding="5,1"
                                                                    CornerRadius="{DynamicResource Radius.Sm}"
                                                                    Background="{DynamicResource Brush.Bg.Tertiary}"
                                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                                    BorderThickness="1"
                                                                    Visibility="{Binding VisionVisibility}">
                                                                <TextBlock Text="视觉"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding ModelName}"
                                                                   FontSize="13"
                                                                   FontWeight="Medium"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" />
                                                    </DockPanel>
                                                </Button>
                                                <TextBlock Text="{Binding EmptyText}"
                                                           Margin="12"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                                           Visibility="{Binding EmptyVisibility}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Popup>
                </Grid>

                <ContentControl x:Name="ImageWorkbenchHost"
                                Margin="0,72,0,0"
                                Visibility="{Binding IsImageWorkbenchVisible, Converter={x:Static views:BoolToVisibility.Instance}}" />
            </Grid>
        </Border>

        <!-- Artifact drawer handle — a slim tab pinned to the right edge of the
             chat area (the seam between chat and the artifact panel). Toggles the
             panel; arrow flips with state. Hidden entirely in MolaGPT-account mode
             and when the conversation has no local artifacts. -->
        <Button x:Name="ArtifactDrawerHandle"
                Grid.Column="2"
                Panel.ZIndex="50"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Width="22" Height="64"
                Margin="0,0,14,0"
                Cursor="Hand"
                BorderThickness="0"
                Command="{Binding ToggleArtifactPanelCommand}"
                ToolTip="产物面板"
                Visibility="{Binding IsArtifactPanelAvailable, Converter={x:Static views:BoolToVisibility.Instance}}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{DynamicResource Brush.Primary}"
                            CornerRadius="8"
                            Opacity="0.92">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="8" ShadowDepth="0" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <Grid>
                <!-- Panel closed → arrow points left (pull out) -->
                <TextBlock Text="&#xE76B;"
                           FontFamily="{DynamicResource Font.Icon}"
                           FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="White"
                           Visibility="{Binding ArtifactPanelVisible, Converter={x:Static views:BoolToVisibilityInverse.Instance}}" />
                <!-- Panel open → arrow points right (push back) -->
                <TextBlock Text="&#xE76C;"
                           FontFamily="{DynamicResource Font.Icon}"
                           FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="White"
                           Visibility="{Binding ArtifactPanelVisible, Converter={x:Static views:BoolToVisibility.Instance}}" />
            </Grid>
        </Button>

        <!-- ========================================================
             ARTIFACT PANEL — session-level files produced by the
             python tool or uploaded by the user. Width is animated by
             MainWindow.xaml.cs in response to ArtifactPanelVisible.
             ======================================================== -->
        <Border x:Name="ArtifactCard"
                Grid.Column="4"
                Background="{DynamicResource Brush.Bg.Primary}"
                CornerRadius="{DynamicResource Radius.Xxl}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1"
                Visibility="Collapsed"
                ClipToBounds="True">
            <Grid Margin="14,14,12,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="2,0,2,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="产物和工作区"
                               VerticalAlignment="Center"
                               FontFamily="{DynamicResource Font.Cjk}"
                               FontWeight="SemiBold"
                               FontSize="{DynamicResource Font.Size.Heading}"
                               Foreground="{DynamicResource Brush.Text.Primary}" />
                    <Button Grid.Column="1"
                            Style="{StaticResource HeaderIconButton}"
                            Command="{Binding ToggleArtifactPanelCommand}"
                            ToolTip="关闭产物面板"
                            Content="&#xE8BB;" />
                </Grid>

                <!-- Empty state -->
                <TextBlock Grid.Row="1"
                           Text="暂无产物"
                           Margin="2,8,2,0"
                           VerticalAlignment="Top"
                           FontFamily="{DynamicResource Font.Cjk}"
                           FontSize="{DynamicResource Font.Size.Small}"
                           Foreground="{DynamicResource Brush.Text.Muted}"
                           Visibility="{Binding Chat.HasArtifacts, Converter={x:Static views:BoolToVisibilityInverse.Instance}}" />

                <!-- Artifact list -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding Chat.HasArtifacts, Converter={x:Static views:BoolToVisibility.Instance}}">
                    <ItemsControl ItemsSource="{Binding Chat.Artifacts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="8"
                                        Background="{DynamicResource Brush.Bg.Elevated}"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Md}"
                                        Cursor="Hand"
                                        ToolTip="{Binding ToolTip}"
                                        MouseLeftButtonUp="ArtifactCard_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Image thumbnail -->
                                        <Border Grid.Column="0"
                                                Width="40" Height="40"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                ClipToBounds="True"
                                                Visibility="{Binding IsImage, Converter={x:Static views:BoolToVisibility.Instance}}">
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding FullPath}" />
                                        </Border>
                                        <!-- Non-image type badge -->
                                        <Border Grid.Column="0"
                                                Width="40" Height="40"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                Background="{DynamicResource Brush.Primary.Tint}"
                                                Visibility="{Binding IsImage, Converter={x:Static views:BoolToVisibilityInverse.Instance}}">
                                            <TextBlock Text="{Binding Extension}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.Primary}" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="{DynamicResource Font.Cjk}"
                                                       FontSize="{DynamicResource Font.Size.Small}"
                                                       Foreground="{DynamicResource Brush.Text.Primary}" />
                                            <TextBlock Text="{Binding SizeLabel}"
                                                       Margin="0,2,0,0"
                                                       FontSize="{DynamicResource Font.Size.XSmall}"
                                                       Foreground="{DynamicResource Brush.Text.Muted}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
    </DockPanel>
    </Border>
</Window>
