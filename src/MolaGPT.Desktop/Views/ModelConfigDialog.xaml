<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MolaGPT.Desktop.Views.ModelConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="模型配置"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="{DynamicResource Font.UI}"
        FontSize="{DynamicResource Font.Size.Body}"
        Foreground="{DynamicResource Brush.Text.Primary}">

    <Grid Margin="24">
        <Border Style="{StaticResource ModalWindowGlow}" />
        <Border Style="{StaticResource ModalWindowSurface}"
                Padding="0">
            <DockPanel LastChildFill="True">
            <!-- Header -->
            <Border DockPanel.Dock="Top"
                    Padding="20,14"
                    BorderBrush="{DynamicResource Brush.Divider}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="DialogTitle"
                               Text="模型配置"
                               FontSize="{DynamicResource Font.Size.Heading}"
                               FontWeight="SemiBold" />
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource HeaderIconButton}"
                            Click="CloseClick">
                        <TextBlock Text="&#xE711;" FontFamily="{DynamicResource Font.Icon}" FontSize="14" />
                    </Button>
                </Grid>
            </Border>

            <!-- Footer buttons -->
            <Border DockPanel.Dock="Bottom"
                    Padding="20,12"
                    BorderBrush="{DynamicResource Brush.Divider}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource OutlineButton}"
                            Content="取消"
                            Width="80"
                            Margin="0,0,8,0"
                            Click="CancelClick" />
                    <Button x:Name="ConfirmButton"
                            Style="{StaticResource PillPrimaryButton}"
                            Content="确定"
                            Width="100"
                            Click="ConfirmClick" />
                </StackPanel>
            </Border>

            <!-- Content area: single edit or batch detect (mutually exclusive) -->
            <Grid>
                <!-- Single-model edit panel -->
                <Grid x:Name="SingleEditPanel">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="20,16">
                <StackPanel>
                    <TextBlock Text="模型 ID" Margin="0,0,0,4"
                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                            CornerRadius="{DynamicResource Radius.Sm}"
                            Padding="12,8" Margin="0,0,0,12">
                        <TextBox x:Name="EditModelId"
                                 Style="{StaticResource InlineTextBox}" />
                    </Border>

                    <TextBlock Text="显示名称" Margin="0,0,0,4"
                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                            CornerRadius="{DynamicResource Radius.Sm}"
                            Padding="12,8" Margin="0,0,0,12">
                        <TextBox x:Name="EditDisplayName"
                                 Style="{StaticResource InlineTextBox}" />
                    </Border>

                    <TextBlock Text="上下文窗口（tokens）" Margin="0,0,0,4"
                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                            CornerRadius="{DynamicResource Radius.Sm}"
                            Padding="12,8" Margin="0,0,0,12">
                        <TextBox x:Name="EditContextWindow"
                                 Style="{StaticResource InlineTextBox}" />
                    </Border>

                    <TextBlock Text="能力" Margin="0,0,0,6"
                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                    <WrapPanel Margin="0,0,0,12">
                        <CheckBox x:Name="ChkVision" Content="视觉" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkTools" Content="工具调用" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkThinking" Content="推理"
                                  Margin="0,0,16,0"
                                  Checked="ChkThinking_Changed"
                                  Unchecked="ChkThinking_Changed" />
                        <CheckBox x:Name="ChkReasoningEffort" Content="推理强度" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkImageEdit" Content="图像编辑" Margin="0,0,16,0" />
                    </WrapPanel>

                    <!-- Thinking config section -->
                    <StackPanel x:Name="ThinkingConfigPanel" Visibility="Collapsed">
                        <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                CornerRadius="{DynamicResource Radius.Sm}"
                                Padding="14,12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="思考参数格式" Margin="0,0,0,6"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.Text.Secondary}" />
                                <ComboBox x:Name="ThinkingKindCombo"
                                          Style="{StaticResource SettingsComboBox}"
                                          Margin="0,0,0,10"
                                          SelectionChanged="ThinkingKindCombo_Changed">
                                    <ComboBoxItem Content="OpenAI Effort" Tag="OpenAiReasoningEffort" />
                                    <ComboBoxItem Content="Anthropic Adaptive" Tag="AnthropicAdaptive" />
                                    <ComboBoxItem Content="Anthropic Budget" Tag="AnthropicBudget" />
                                    <ComboBoxItem Content="DeepSeek V4" Tag="DeepSeekV4" />
                                    <ComboBoxItem Content="Gemini Level" Tag="GeminiThinkingLevel" />
                                    <ComboBoxItem Content="Gemini Budget" Tag="GeminiBudget" />
                                    <ComboBoxItem Content="Qwen Budget" Tag="QwenThinkingBudget" />
                                </ComboBox>

                                <TextBlock Text="默认强度" Margin="0,0,0,4"
                                           Foreground="{DynamicResource Brush.Text.Secondary}" />
                                <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Padding="12,8" Margin="0,0,0,10">
                                    <TextBox x:Name="EditDefaultEffort"
                                             Style="{StaticResource InlineTextBox}" />
                                </Border>

                                <StackPanel x:Name="BudgetRangePanel">
                                    <TextBlock Text="Budget 范围 (tokens)" Margin="0,0,0,6"
                                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="最小:" VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   Foreground="{DynamicResource Brush.Text.Muted}" />
                                        <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                Padding="8,6" Width="100">
                                            <TextBox x:Name="EditBudgetMin"
                                                     Style="{StaticResource InlineTextBox}" />
                                        </Border>
                                        <TextBlock Text="最大:" VerticalAlignment="Center"
                                                   Margin="16,0,6,0"
                                                   Foreground="{DynamicResource Brush.Text.Muted}" />
                                        <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                Padding="8,6" Width="100">
                                            <TextBox x:Name="EditBudgetMax"
                                                     Style="{StaticResource InlineTextBox}" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="默认:" VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   Foreground="{DynamicResource Brush.Text.Muted}" />
                                        <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                                CornerRadius="{DynamicResource Radius.Sm}"
                                                Padding="8,6" Width="100">
                                            <TextBox x:Name="EditBudgetDefault"
                                                     Style="{StaticResource InlineTextBox}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- System Prompt -->
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="系统提示词（可选）"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                   Margin="0,0,0,6" />
                        <Border Background="{DynamicResource Brush.Bg.Elevated}"
                                CornerRadius="{DynamicResource Radius.Sm}"
                                Padding="10,8">
                            <TextBox x:Name="EditSystemPrompt"
                                     Style="{StaticResource InlineTextBox}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="60"
                                     MaxHeight="160"
                                     VerticalScrollBarVisibility="Auto" />
                        </Border>
                        <TextBlock Text="为该模型设置默认系统提示词，对话级提示词可覆盖此设置"
                                   FontSize="11"
                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </StackPanel>
                    </ScrollViewer>
                </Grid>

            <!-- Batch detect panel (hidden by default) -->
            <DockPanel x:Name="BatchPanel" Visibility="Collapsed">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                            Margin="20,12,20,8">
                    <CheckBox x:Name="ChkSelectAll"
                              Content="全选"
                              Checked="SelectAll_Changed"
                              Unchecked="SelectAll_Changed" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,0,20,8">
                    <ItemsControl x:Name="BatchModelList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                                        CornerRadius="{DynamicResource Radius.Sm}"
                                        Padding="12,8"
                                        Margin="0,0,0,4"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  IsEnabled="{Binding IsEnabled}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0" />
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Entry.Id}"
                                                           FontWeight="SemiBold"
                                                           FontSize="{DynamicResource Font.Size.Small}" />
                                                <TextBlock Text="{Binding StatusText}"
                                                           Margin="8,0,0,0"
                                                           FontSize="{DynamicResource Font.Size.XSmall}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding CapabilitySummary}"
                                                       FontSize="{DynamicResource Font.Size.XSmall}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
            </Grid>
        </DockPanel>
        </Border>
    </Grid>
</Window>
