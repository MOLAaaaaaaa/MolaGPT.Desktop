<Window x:Class="MolaGPT.Desktop.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="登录 MolaGPT"
        Icon="/Assets/app-logo.png"
        Width="420" Height="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="{DynamicResource Font.UI}"
        FontSize="{DynamicResource Font.Size.Body}"
        mc:Ignorable="d">

    <Grid Margin="24">
        <Border Style="{StaticResource ModalWindowGlow}" />
        <Border Style="{StaticResource ModalWindowSurface}"
                Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock Text="登录 MolaGPT"
                               FontSize="{DynamicResource Font.Size.Heading}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center" />
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource HeaderIconButton}"
                            Click="CloseClick"
                            ToolTip="关闭">
                        <TextBlock Text="&#xE711;" FontFamily="{DynamicResource Font.Icon}" FontSize="14" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="用户名"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="{DynamicResource Font.Size.Small}"
                               Margin="0,0,0,4" />
                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                            CornerRadius="{DynamicResource Radius.Sm}"
                            Padding="12,8"
                            Margin="0,0,0,12">
                        <TextBox x:Name="UsernameBox"
                                 Style="{StaticResource InlineTextBox}" />
                    </Border>

                    <TextBlock Text="密码"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="{DynamicResource Font.Size.Small}"
                               Margin="0,0,0,4" />
                    <Border Background="{DynamicResource Brush.Bg.Tertiary}"
                            CornerRadius="{DynamicResource Radius.Sm}"
                            Padding="12,8"
                            Margin="0,0,0,12">
                        <PasswordBox x:Name="PasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource Brush.Text.Primary}"
                                     FontFamily="{DynamicResource Font.UI}"
                                     FontSize="{DynamicResource Font.Size.Body}" />
                    </Border>

                    <TextBlock Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="{DynamicResource Font.Size.Small}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               Text="密码以 SHA-256 加密传输，登录凭据通过 Windows DPAPI 加密保存在本机。" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Brush.Divider}" />
                        <TextBlock Grid.Column="1"
                                   Text="或使用第三方账号"
                                   Margin="10,0"
                                   FontSize="{DynamicResource Font.Size.Small}"
                                   Foreground="{DynamicResource Brush.Text.Muted}" />
                        <Border Grid.Column="2"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Brush.Divider}" />
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                x:Name="GoogleButton"
                                Style="{StaticResource OutlineButton}"
                                Height="40"
                                Click="GoogleLoginClick"
                                ToolTip="使用 Google 账号登录">
                            <TextBlock Text="Google"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="2"
                                x:Name="MicrosoftButton"
                                Style="{StaticResource OutlineButton}"
                                Height="40"
                                Click="MicrosoftLoginClick"
                                ToolTip="使用 Microsoft 账号登录">
                            <TextBlock Text="Microsoft"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="4"
                                x:Name="LinuxDoButton"
                                Style="{StaticResource OutlineButton}"
                                Height="40"
                                Click="LinuxDoLoginClick"
                                ToolTip="使用 Linux Do 账号登录">
                            <TextBlock Text="Linux Do"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Button>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="2"
                        x:Name="ErrorPanel"
                        Margin="0,14,0,0"
                        Padding="10,8"
                        MaxHeight="92"
                        Background="{DynamicResource Brush.Bg.Tertiary}"
                        BorderBrush="{DynamicResource Brush.Error}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius.Sm}"
                        Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="ErrorText"
                                   Foreground="{DynamicResource Brush.Error}"
                                   FontSize="{DynamicResource Font.Size.Small}"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Style="{StaticResource OutlineButton}"
                            Content="取消"
                            Width="86"
                            Height="42"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Click="CloseClick" />
                    <Button Grid.Column="2"
                            x:Name="LoginButton"
                            Style="{StaticResource PillPrimaryButton}"
                            Content="登录"
                            Width="104"
                            Height="42"
                            VerticalAlignment="Center"
                            Click="LoginClick" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
