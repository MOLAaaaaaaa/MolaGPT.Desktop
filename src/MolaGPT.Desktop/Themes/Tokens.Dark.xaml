<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- Dark theme tokens. Keep a neutral gray scale: canvas black, primary
         #1a1a1a, secondary #2d2d2d, tertiary #3a3a3a. -->

    <Color x:Key="Color.Primary">#FFBE727F</Color>
    <Color x:Key="Color.Primary.Hover">#FFE1A3AF</Color>
    <Color x:Key="Color.Primary.Active">#FFA05A66</Color>
    <Color x:Key="Color.Primary.Soft">#2ECF8996</Color>
    <Color x:Key="Color.Primary.Tint">#24BE727F</Color>
    <Color x:Key="Color.Primary.Blockquote">#1ABE727F</Color>
    <Color x:Key="Color.Primary.Border">#52BE727F</Color>

    <Color x:Key="Color.Bg.Canvas">#FF000000</Color>
    <Color x:Key="Color.Bg.Primary">#FF1A1A1A</Color>
    <Color x:Key="Color.Bg.Secondary">#FF2D2D2D</Color>
    <Color x:Key="Color.Bg.Tertiary">#FF3A3A3A</Color>
    <Color x:Key="Color.Bg.Elevated">#FF1A1A1A</Color>
    <Color x:Key="Color.Bg.HoverOverlay">#14FFFFFF</Color>

    <Color x:Key="Color.Text.Primary">#FFE0E0E0</Color>
    <Color x:Key="Color.Text.Secondary">#FFA0A0A0</Color>
    <Color x:Key="Color.Text.Muted">#FF777777</Color>
    <Color x:Key="Color.Text.OnPrimary">#FFFFFFFF</Color>

    <Color x:Key="Color.Border">#FF404040</Color>
    <Color x:Key="Color.Border.Strong">#1AFFFFFF</Color>
    <Color x:Key="Color.Border.Subtle">#14FFFFFF</Color>
    <Color x:Key="Color.Divider">#FF333333</Color>

    <Color x:Key="Color.Success">#FF4CAF50</Color>
    <Color x:Key="Color.Warning">#FFFFB74D</Color>
    <Color x:Key="Color.Error">#FFF44336</Color>
    <Color x:Key="Color.Info">#FF64B5F6</Color>

    <Color x:Key="Color.Shadow.Soft">#33000000</Color>
    <Color x:Key="Color.Shadow.Medium">#7F000000</Color>

    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}" />
    <SolidColorBrush x:Key="Brush.Primary.Hover" Color="{StaticResource Color.Primary.Hover}" />
    <SolidColorBrush x:Key="Brush.Primary.Active" Color="{StaticResource Color.Primary.Active}" />
    <SolidColorBrush x:Key="Brush.Primary.Soft" Color="{StaticResource Color.Primary.Soft}" />
    <SolidColorBrush x:Key="Brush.Primary.Tint" Color="{StaticResource Color.Primary.Tint}" />
    <SolidColorBrush x:Key="Brush.Primary.Blockquote" Color="{StaticResource Color.Primary.Blockquote}" />
    <SolidColorBrush x:Key="Brush.Primary.Border" Color="{StaticResource Color.Primary.Border}" />
    <SolidColorBrush x:Key="Brush.Bg.Canvas" Color="{StaticResource Color.Bg.Canvas}" />
    <SolidColorBrush x:Key="Brush.Bg.Primary" Color="{StaticResource Color.Bg.Primary}" />
    <SolidColorBrush x:Key="Brush.Bg.Secondary" Color="{StaticResource Color.Bg.Secondary}" />
    <SolidColorBrush x:Key="Brush.Bg.Tertiary" Color="{StaticResource Color.Bg.Tertiary}" />
    <SolidColorBrush x:Key="Brush.Bg.Elevated" Color="{StaticResource Color.Bg.Elevated}" />
    <SolidColorBrush x:Key="Brush.Bg.HoverOverlay" Color="{StaticResource Color.Bg.HoverOverlay}" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{StaticResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.OnPrimary" Color="{StaticResource Color.Text.OnPrimary}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.Border.Strong" Color="{StaticResource Color.Border.Strong}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Divider" Color="{StaticResource Color.Divider}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}" />

    <sys:Double x:Key="Size.Sidebar.Width">280</sys:Double>
    <sys:Double x:Key="Size.Sidebar.Collapsed">80</sys:Double>
    <sys:Double x:Key="Size.TopBar.Height">56</sys:Double>
    <sys:Double x:Key="Size.Composer.MaxWidth">900</sys:Double>
    <sys:Double x:Key="Size.Composer.MinHeight">120</sys:Double>
    <sys:Double x:Key="Size.SendButton">32</sys:Double>

    <CornerRadius x:Key="Radius.2xs">4</CornerRadius>
    <CornerRadius x:Key="Radius.Web.Sm">6</CornerRadius>
    <CornerRadius x:Key="Radius.Xs">4</CornerRadius>
    <CornerRadius x:Key="Radius.Sm">6</CornerRadius>
    <CornerRadius x:Key="Radius.Md">10</CornerRadius>
    <CornerRadius x:Key="Radius.Lg">16</CornerRadius>
    <CornerRadius x:Key="Radius.Xl">20</CornerRadius>
    <CornerRadius x:Key="Radius.Xxl">24</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">999</CornerRadius>
    <CornerRadius x:Key="Radius.UserBubble">10,0,10,10</CornerRadius>

    <Thickness x:Key="Padding.Tight">8</Thickness>
    <Thickness x:Key="Padding.Md">12</Thickness>
    <Thickness x:Key="Padding.Lg">16</Thickness>
    <Thickness x:Key="Padding.Xl">20</Thickness>

    <FontFamily x:Key="Font.Latin">pack://application:,,,/Assets/GeistVariableVF.ttf#Geist Variable, Segoe UI Variable, Segoe UI, Helvetica Neue, Helvetica, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Cjk">Noto Sans CJK SC, Noto Sans SC, PingFang SC, Hiragino Sans GB, Microsoft YaHei UI, Microsoft YaHei, SimHei, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.UI">pack://application:,,,/Assets/GeistVariableVF.ttf#Geist Variable, Segoe UI Variable, Segoe UI, Noto Sans CJK SC, Noto Sans SC, PingFang SC, Hiragino Sans GB, Microsoft YaHei UI, Microsoft YaHei, Helvetica Neue, Helvetica, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">SFMono-Regular, Consolas, Liberation Mono, Menlo, Cascadia Code, Cascadia Mono, Courier, monospace</FontFamily>
    <FontFamily x:Key="Font.Icon">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
    <FontFamily x:Key="Font.FA.Solid">/Assets/fa-solid-900.ttf#Font Awesome 5 Free</FontFamily>
    <sys:Double x:Key="Font.Size.XSmall">11</sys:Double>
    <sys:Double x:Key="Font.Size.Small">12</sys:Double>
    <sys:Double x:Key="Font.Size.Body">14</sys:Double>
    <sys:Double x:Key="Font.Size.BodyLg">15</sys:Double>
    <sys:Double x:Key="Font.Size.Heading">18</sys:Double>
    <sys:Double x:Key="Font.Size.Title">24</sys:Double>
    <sys:Double x:Key="Font.Size.Welcome">28</sys:Double>

    <KeySpline x:Key="Easing.EaseOut">0.4,0,0.2,1</KeySpline>
    <Duration x:Key="Duration.Fast">0:0:0.2</Duration>
    <Duration x:Key="Duration.Med">0:0:0.3</Duration>
    <Duration x:Key="Duration.Slide">0:0:0.5</Duration>
    <Duration x:Key="Duration.Pulse">0:0:1.2</Duration>

</ResourceDictionary>
