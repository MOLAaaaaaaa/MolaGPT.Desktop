<UserControl x:Class="MolaGPT.Desktop.Controls.RevealableSecretBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <PasswordBox x:Name="Pw"
                     Grid.Column="0"
                     VerticalContentAlignment="Center"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource Brush.Text.Primary}"
                     FontFamily="{DynamicResource Font.UI}"
                     FontSize="{DynamicResource Font.Size.Body}"
                     PasswordChanged="Pw_PasswordChanged" />

        <TextBox x:Name="Tb"
                 Grid.Column="0"
                 Visibility="Collapsed"
                 VerticalContentAlignment="Center"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource Brush.Text.Primary}"
                 FontFamily="{DynamicResource Font.UI}"
                 FontSize="{DynamicResource Font.Size.Body}"
                 TextChanged="Tb_TextChanged" />

        <Button x:Name="EyeBtn"
                Grid.Column="1"
                Click="ToggleReveal"
                Cursor="Hand"
                Padding="6,0"
                Margin="6,0,0,0"
                ToolTip="显示">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.Bg.HoverOverlay}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <TextBlock x:Name="EyeGlyph"
                       Text="&#xE7B3;"
                       FontFamily="{DynamicResource Font.Icon}"
                       FontSize="14"
                       Foreground="{DynamicResource Brush.Text.Muted}" />
        </Button>
    </Grid>
</UserControl>
